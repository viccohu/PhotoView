<Page
    x:Class="PhotoView.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TreeView
            Grid.Column="0"
            Grid.Row="0"
            Grid.RowSpan="2"
            x:Name="FolderTreeView"
            ItemsSource="{x:Bind ViewModel.FolderTree}"
            Expanding="FolderTreeView_Expanding"
            ItemInvoked="FolderTreeView_ItemInvoked"
            Margin="4">

            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="models:FolderNode">
                    <TreeViewItem
                        ItemsSource="{x:Bind Children}"
                        Content="{x:Bind Name}" />
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <Grid Grid.Column="1" Grid.Row="0" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <BreadcrumbBar
                Grid.Column="0"
                x:Name="BreadcrumbBar"
                ItemsSource="{x:Bind ViewModel.BreadcrumbPath}"
                ItemClicked="BreadcrumbBar_ItemClicked">
                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate x:DataType="models:FolderNode">
                        <TextBlock Text="{x:Bind Name}"/>
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button x:Name="EditButton" Content="编辑">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="分享" Icon="Share"/>
                            <MenuFlyoutItem Text="复制" Icon="Copy"/>
                            <MenuFlyoutItem Text="删除" Icon="Delete"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="重命名"/>
                            <MenuFlyoutItem Text="选择"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <GridView
            Grid.Column="1"
            Grid.Row="1"
            x:Name="ImageGridView"
            ItemsSource="{x:Bind ViewModel.Images}"
            Padding="4">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ImageFileInfo">
                    <Border
                        Margin="4"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <Grid>
                            <Image
                                Source="{x:Bind ImageFile.Path}"
                                Stretch="UniformToFill"
                                Height="200"
                                Width="{x:Bind AutoWidth}"/>
                            <Border
                                Background="Transparent"
                                RightTapped="Image_RightTapped">
                                <FlyoutBase.AttachedFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="分享" Icon="Share" Click="Share_Click"/>
                                        <MenuFlyoutItem Text="保存" Icon="Save" Click="Save_Click"/>
                                        <MenuFlyoutItem Text="删除" Icon="Delete" Click="Delete_Click"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="调整大小"/>
                                        <MenuFlyoutItem Text="移动"/>
                                    </MenuFlyout>
                                </FlyoutBase.AttachedFlyout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        Orientation="Horizontal"
                        ItemHeight="200"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</Page>
