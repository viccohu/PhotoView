<Page
    x:Class="PhotoView.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:controls="using:PhotoView.Controls"
    xmlns:local="using:PhotoView.Views"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <!-- ThumbnailConverter is a legacy path; MainPage uses ImageFileInfo.Thumbnail directly. -->
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NodeTypeToIconConverter x:Key="NodeTypeToIconConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>

        <DataTemplate x:Key="FoldIconTemplate">
            <Viewbox Width="14" Height="14">
                <Canvas Width="76.47" Height="76.47">
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="m64.01,23.92v27.16c0,2.31-1.87,4.17-4.17,4.17H14.92c-2.31,0-4.17-1.87-4.17-4.17v-1.29h43.63c2.31,0,4.17-1.87,4.17-4.17v-25.88h1.29c2.31,0,4.17,1.87,4.17,4.17Z"/>
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="m72.75,32.66v27.16c0,2.31-1.87,4.17-4.17,4.17H23.66c-2.31,0-4.17-1.87-4.17-4.17v-1.29h43.63c2.31,0,4.17-1.87,4.17-4.17v-25.88h1.29c2.31,0,4.17,1.87,4.17,4.17Z"/>
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="M6.17,11 H51.1 A4.17,4.17 0 0 1 55.27,15.17 V42.34 A4.17,4.17 0 0 1 51.1,46.51 H6.17 A4.17,4.17 0 0 1 2,42.34 V15.17 A4.17,4.17 0 0 1 6.17,11 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>

        <DataTemplate x:Key="ToolbarFoldIconTemplate">
            <Viewbox Width="18" Height="18">
                <Canvas Width="76.47" Height="76.47">
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="m64.01,23.92v27.16c0,2.31-1.87,4.17-4.17,4.17H14.92c-2.31,0-4.17-1.87-4.17-4.17v-1.29h43.63c2.31,0,4.17-1.87,4.17-4.17v-25.88h1.29c2.31,0,4.17,1.87,4.17,4.17Z"/>
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="m72.75,32.66v27.16c0,2.31-1.87,4.17-4.17,4.17H23.66c-2.31,0-4.17-1.87-4.17-4.17v-1.29h43.63c2.31,0,4.17-1.87,4.17-4.17v-25.88h1.29c2.31,0,4.17,1.87,4.17,4.17Z"/>
                    <Path
                        Fill="{ThemeResource TextFillColorPrimaryBrush}"
                        Data="M6.17,11 H51.1 A4.17,4.17 0 0 1 55.27,15.17 V42.34 A4.17,4.17 0 0 1 51.1,46.51 H6.17 A4.17,4.17 0 0 1 2,42.34 V15.17 A4.17,4.17 0 0 1 6.17,11 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>
        
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter 
                                x:Name="ContentPresenter"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorDisabledBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="NavigationDrawerRoot"
            Grid.Column="0"
            Grid.Row="0"
            Grid.RowSpan="3"
            Width="265"
            Margin="0,6,0,6"
            HorizontalAlignment="Left"
            PointerEntered="NavigationDrawerRoot_PointerEntered"
            PointerExited="NavigationDrawerRoot_PointerExited">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="0,8,8,0"/>

            <Button
                x:Name="NavigationDrawerToggleButton"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Width="25"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0"
                Click="NavigationDrawerToggleButton_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                </Button.Resources>
                <FontIcon
                    Glyph="&#xE76C;"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    RenderTransformOrigin="0.5,0.5">
                    <FontIcon.RenderTransform>
                        <RotateTransform x:Name="NavigationDrawerChevronTransform" Angle="180"/>
                    </FontIcon.RenderTransform>
                </FontIcon>
            </Button>

            <Border
                x:Name="NavigationDrawerHeader"
                Grid.Row="0"
                Grid.Column="1"
                Padding="12"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8F1;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16"/>
                        <TextBlock Text="资源路径" Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                x:Name="NavigationDrawerTree"
                Grid.Row="1"
                Grid.Column="1"
                Padding="6"
                Background="Transparent"
                BorderBrush="{ThemeResource ControlAltFillColorTertiaryBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0">
                <TreeView
                    x:Name="FolderTreeView"
                    ItemsSource="{x:Bind ViewModel.FolderTree}"
                    Expanding="FolderTreeView_Expanding"
                    ItemInvoked="FolderTreeView_ItemInvoked">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:FolderNode">
                            <TreeViewItem
                                ItemsSource="{x:Bind Children}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HasUnrealizedChildren="{x:Bind HasExpandableChildren, Mode=OneWay}"
                                RightTapped="TreeViewItem_RightTapped">
                                <Grid Tag="{x:Bind}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FlyoutBase.AttachedFlyout>
                                        <MenuFlyout Placement="Bottom" Opening="FolderTreeMenuFlyout_Opening">
                                            <MenuFlyoutItem Text="放进预览载入区" Icon="Add" Click="AddFolderToPreview_Click"/>
                                            <MenuFlyoutItem Text="在资源管理器中打开" Icon="OpenFile" Click="OpenFolderInExplorer_Click"/>
                                            <MenuFlyoutSeparator Tag="PinSectionSeparator"/>
                                            <MenuFlyoutItem Tag="PinFolder" Text="固定到常用文件夹" Icon="Pin" Click="PinFolder_Click"/>
                                            <MenuFlyoutItem Tag="UnpinFolder" Text="取消固定" Icon="UnPin" Click="UnpinFolder_Click"/>
                                            <MenuFlyoutSeparator Tag="ExternalDeviceSectionSeparator"/>
                                            <MenuFlyoutItem Tag="RefreshExternalDevices" Text="刷新外接设备" Icon="Refresh" Click="RefreshExternalDevices_Click"/>
                                        </MenuFlyout>
                                    </FlyoutBase.AttachedFlyout>
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="{x:Bind NodeType, Mode=OneWay, Converter={StaticResource NodeTypeToIconConverter}}"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Margin="0,0,6,0"/>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </Grid>

        <Border
            Grid.Column="1"
            Grid.Row="0"
            Margin="4,6,30,0"
            Padding="10,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Visibility="{x:Bind ViewModel.SelectedFolder, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Glyph="{x:Bind ViewModel.SelectedFolder, Mode=OneWay, Converter={StaticResource NodeTypeToIconConverter}}"
                        FontSize="20"
                        VerticalAlignment="Center"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.SelectedFolder.Name, Mode=OneWay}"
                        Style="{ThemeResource BodyLargeTextBlockStyle}"
                        FontSize="28"
                        VerticalAlignment="Center"/>
                    <Border
                     Width="1"
                     Background="White"
                     Opacity="0.2"
                     Margin="3,0,2,0"
                     />
                    <Border
                        Padding="8,2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        VerticalAlignment="Center">
                        <TextBlock
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.75"
                            VerticalAlignment="Center">
                            <Run Text="选中 "/>
                            <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}"/>
                            <Run Text=" 张/总计 "/>
                            <Run Text="{x:Bind ViewModel.TotalPhotoCount, Mode=OneWay}"/>
                            <Run Text=" 张"/>
                        </TextBlock>
                    </Border>
                    <Border
                        Padding="8,2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.PendingDeleteCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                            <TextBlock
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                VerticalAlignment="Center">
                                <Run Text="{x:Bind ViewModel.PendingDeleteCount, Mode=OneWay}"/>
                                <Run Text=" 预删除"/>
                            </TextBlock>
                            <Button
                                Click="ClearAllPendingDelete_Click"
                                Padding="4,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                                <FontIcon
                                    Glyph="&#xE711;"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="0,8,0,12"
                    
                    Visibility="Collapsed">
                    <Border
                        Padding="8,2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{x:Bind ViewModel.SubFolderCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7">
                            <Run Text="{x:Bind ViewModel.SubFolderCount, Mode=OneWay}"/>
                            <Run Text=" folders"/>
                        </TextBlock>
                    </Border>
                    <Border
                        Padding="8,2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                        BorderThickness="1"
                        Margin="10,0,0,0"
                        CornerRadius="4">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7">
                            <Run Text="选中 "/>
                            <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}"/>
                            <Run Text=" 张/总计 "/>
                            <Run Text="{x:Bind ViewModel.TotalPhotoCount, Mode=OneWay}"/>
                            <Run Text=" 张"/>
                        </TextBlock>
                    </Border>
                    <Border
                        Padding="8,2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                        BorderThickness="1"
                        Margin="10,0,0,0"
                        CornerRadius="4"
                        Visibility="{x:Bind ViewModel.PendingDeleteCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                VerticalAlignment="Center">
                                <Run Text="预删除 "/>
                                <Run Text="{x:Bind ViewModel.PendingDeleteCount, Mode=OneWay}"/>
                                <Run Text=" 张"/>
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Click="ClearAllPendingDelete_Click"
                                Padding="4,0"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                                <FontIcon 
                                    Glyph="&#xE711;" 
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="PageCommandBar" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Visibility="Collapsed">
                <Button 
                    x:Name="ExportButton" 
                    Padding="8"
                    Click="ExportButton_Click">
                    <FontIcon Glyph="&#xE72D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontWeight="Light" FontSize="16"/>
                </Button>
                <Button 
                    x:Name="DeleteButton" 
                    Padding="8"
                    Click="DeleteButton_Click"
                    IsEnabled="{x:Bind ViewModel.PendingDeleteCount, Mode=OneWay, Converter={StaticResource IntToBoolConverter}}">
                    <FontIcon Glyph="&#xE74D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontWeight="Normal" FontSize="16"/>
                </Button>
                <SplitButton x:Name="FilterSplitButton" Padding="8" Click="FilterSplitButton_Click">
                    <SplitButton.Content>
                        <FontIcon Glyph="&#xE71C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontWeight="Normal" FontSize="16"/>
                    </SplitButton.Content>
                    <SplitButton.Flyout>
                        <Flyout Placement="Bottom">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="16"/>
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <local:FilterFlyout x:Name="FilterFlyoutControl" ShowBurstFilter="True"/>
                        </Flyout>
                    </SplitButton.Flyout>
                </SplitButton>
                <DropDownButton Padding="8">
                    <DropDownButton.Content>
                        <FontIcon Glyph="&#xeca5;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontWeight="Normal" FontSize="16"/>
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Small" Tag="Small" Click="ThumbnailSize_Click"/>
                            <MenuFlyoutItem Text="Medium" Tag="Medium" Click="ThumbnailSize_Click"/>
                            <MenuFlyoutItem Text="Large" Tag="Large" Click="ThumbnailSize_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>
        </Border>


        <Border
            x:Name="FolderDrawerRoot"
            Grid.Column="1"
            Grid.Row="1"
            Margin="4,0,30,0"
            Padding="10,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="0,0,8,8"
            Visibility="Visible">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.BreadcrumbPath.Count, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <Button
                            x:Name="BackButton"
                            Margin="0,3,0,0"
                            ToolTipService.ToolTip="Back"
                            Click="BackButton_Click"
                            IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                            Style="{StaticResource BreadcrumbButtonStyle}">
                            <FontIcon Glyph="&#xE72B;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12"/>
                        </Button>
                        <Button
                            x:Name="UpButton"
                            Margin="0,3,0,0"
                            ToolTipService.ToolTip="Go up one level"
                            Click="UpButton_Click"
                            IsEnabled="{x:Bind ViewModel.CanGoUp, Mode=OneWay}"
                            Style="{StaticResource BreadcrumbButtonStyle}">
                            <FontIcon Glyph="&#xE74A;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12"/>
                        </Button>
                        <Button
                            x:Name="RefreshButton"
                            Margin="0,3,0,0"
                            ToolTipService.ToolTip="Refresh"
                            Click="RefreshButton_Click"
                            Style="{StaticResource BreadcrumbButtonStyle}">
                            <FontIcon Glyph="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12"/>
                        </Button>

                        <BreadcrumbBar
                            x:Name="BreadcrumbBar"
                            Margin="12,0,0,0"
                            ItemsSource="{x:Bind ViewModel.BreadcrumbPath}"
                            ItemClicked="BreadcrumbBar_ItemClicked">
                            <BreadcrumbBar.ItemTemplate>
                                <DataTemplate x:DataType="models:FolderNode">
                                    <TextBlock Text="{x:Bind Name}"/>
                                </DataTemplate>
                            </BreadcrumbBar.ItemTemplate>
                        </BreadcrumbBar>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Margin="0,0,34,0"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <FontIcon
                            Glyph="&#xE8B7;"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="14"
                            VerticalAlignment="Center"/>
                        <TextBlock
                            Text="文件夹"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                        <TextBlock
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.7"
                            VerticalAlignment="Center">
                            <Run Text="{x:Bind ViewModel.SubFolderCount, Mode=OneWay}"/>
                            <Run Text=" 个"/>
                        </TextBlock>
                    </StackPanel>
                    <Button
                        x:Name="FolderDrawerToggleButton"
                        Grid.Column="1"
                        Padding="8,4"
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Click="FolderDrawerToggleButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Grid Width="18" Height="14" VerticalAlignment="Center">
                                <Path
                                    x:Name="FolderDrawerClosedIcon"
                                    Data="m57.91,17.52H7.55c-3.18,0-5.76,2.17-5.76,4.84v15.81c0,2.67,2.59,4.84,5.76,4.84h50.36c3.18,0,5.76-2.17,5.76-4.84v-15.81c0-2.67-2.59-4.84-5.76-4.84Zm-18.2,14.48h-13.63c-1.39,0-2.51-1.12-2.51-2.5s1.12-2.5,2.51-2.5h13.63c1.39,0,2.51,1.12,2.51,2.5s-1.12,2.5-2.51,2.5Z M8.18,13.56h49.64c2.31,0,3.85-1.19,2.89-2.25l-6.71-7.38c-.52-.57-1.65-.93-2.89-.93H14.89c-1.25,0-2.38.36-2.89.93l-6.71,7.38c-.96,1.05.58,2.25,2.89,2.25Z"
                                    Fill="#10B0FF"
                                    Stretch="Uniform"/>
                                <Path
                                    x:Name="FolderDrawerOpenIcon"
                                    Data="m61.25,18.42l-5.33-5.86h1.89c2.31,0,3.85-1.19,2.89-2.25l-6.71-7.38c-.52-.57-1.65-.93-2.89-.93H14.89c-1.25,0-2.38.36-2.89.93l-6.71,7.38c-.96,1.05.58,2.25,2.89,2.25h1.89l-4.91,5.4c-1.99.76-3.38,2.45-3.38,4.4l1,15.81c0,2.67,2.59,4.84,5.76,4.84h48.36c3.18,0,5.76-2.17,5.76-4.84l1-15.81c0-1.62-.96-3.06-2.42-3.94Zm-8.05-5.86s.05.03.06.05l4.46,4.91H8.27l4.47-4.91s.05-.03.06-.05h40.4Zm-13.65,23.44h-13.63c-1.39,0-2.51-1.12-2.51-2.5s1.12-2.5,2.51-2.5h13.63c1.39,0,2.51,1.12,2.51,2.5s-1.12,2.5-2.51,2.5Z"
                                    Fill="#10B0FF"
                                    Stretch="Uniform"
                                    Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock
                                Text="文件夹抽屉"
                                Style="{ThemeResource BodyTextBlockStyle}"
                          
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.7"
                                VerticalAlignment="Center">
                                <Run Text="{x:Bind ViewModel.SubFolderCount, Mode=OneWay}"/>
                            </TextBlock>
                            <FontIcon
                                x:Name="FolderDrawerChevron"
                                Glyph="&#xE70D;"
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                FontSize="1"
                                RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform x:Name="FolderDrawerChevronTransform" Angle="0"/>
                                </FontIcon.RenderTransform>
                            </FontIcon>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid
                    x:Name="FolderDrawerContentHost"
                    Visibility="Collapsed"
                    MaxHeight="0"
                    Opacity="0"
                    SizeChanged="FolderDrawerContentHost_SizeChanged">
                    <Grid.Clip>
                        <RectangleGeometry x:Name="FolderDrawerContentClip"/>
                    </Grid.Clip>
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="FolderDrawerContentTransform" Y="-8"/>
                    </Grid.RenderTransform>
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border
                            Grid.Row="0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid Padding="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="名称"
                                Margin="36,0,0,0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="创建时间"
                                VerticalAlignment="Center"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>
                    <ListView
                        x:Name="SubFolderGridView"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.CurrentSubFolders}"
                        SelectionMode="Single"
                        DoubleTapped="SubFolderGridView_DoubleTapped"
                        Visibility="Visible"
                        Opacity="1"
                        Padding="0"
                        Margin="0">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection/>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FolderNode">
                            <Grid
                                Height="36"
                                Padding="12,0"
                                Tag="{x:Bind}"
                                RightTapped="SubFolderItem_RightTapped">
                                <FlyoutBase.AttachedFlyout>
                                    <MenuFlyout Placement="Bottom" Opening="SubFolderMenuFlyout_Opening">
                                        <MenuFlyoutItem Tag="PinFolder" Text="固定到常用文件夹" Icon="Pin" Click="PinSubFolder_Click"/>
                                        <MenuFlyoutItem Tag="UnpinFolder" Text="取消固定" Icon="UnPin" Click="UnpinSubFolder_Click"/>
                                        <MenuFlyoutSeparator Tag="PinSectionSeparator"/>
                                        <MenuFlyoutItem Tag="RefreshExternalDevices" Text="刷新外接设备" Icon="Refresh" Click="RefreshExternalDevices_Click"/>
                                        <MenuFlyoutSeparator Tag="ExternalDeviceSectionSeparator"/>
                                        <MenuFlyoutItem Text="放进预览载入区" Icon="Add" Click="AddSubFolderToPreview_Click"/>
                                        <MenuFlyoutItem Text="在资源管理器中打开" Icon="OpenFile" Click="OpenSubFolderInExplorer_Click"/>
                                    </MenuFlyout>
                                </FlyoutBase.AttachedFlyout>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                        <Grid
                                            Grid.Column="0"
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center">
                                            <FontIcon
                                                Glyph="{Binding Converter={StaticResource NodeTypeToIconConverter}}"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="17"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding HasListIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                            <Image
                                                Source="{x:Bind ListIcon, Mode=OneWay}"
                                                Width="20"
                                                Height="20"
                                                Stretch="Uniform"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding HasListIcon, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center"
                                            Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </Grid>
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind CreatedTimeText, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center"
                                            Style="{ThemeResource BodyTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="MinHeight" Value="36"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    </ListView>
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>


        <GridView
            x:Name="ImageGridView"
            Grid.Column="1"
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Images}"
            SelectionMode="Extended"
            CanDragItems="True"
            CanReorderItems="False"
            SelectionChanged="ImageGridView_SelectionChanged"
            DragItemsStarting="ImageGridView_DragItemsStarting"
            ContainerContentChanging="ImageGridView_ContainerContentChanging"
            SizeChanged="ImageGridView_SizeChanged"
            
            Margin="0,4,0,0"
            Padding="0,0,4,4">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ImageFileInfo">
                    <Grid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Tag="{x:Bind}"
                        PointerPressed="ImageItem_PointerPressed"
                        Tapped="ImageItem_Tapped"
                        RightTapped="ImageItem_RightTapped">
                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Text="在资源管理器中打开" Icon="OpenFile" Click="OpenImageInExplorer_Click"/>
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                        <Border
                            Margin="10,10,10,0"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{x:Bind BurstAccentColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"
                            BorderThickness="0"
                            Opacity="0.55"
                            Visibility="{x:Bind IsBurstCover, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Border
                            Margin="5,5,5,0"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{x:Bind BurstAccentColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"
                            BorderThickness="0"
                            Opacity="0.72"
                            Visibility="{x:Bind IsBurstCover, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Border
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="0">
                            <Grid Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image
                                    x:Name="thumbnailImage"
                                    Source="{x:Bind Thumbnail, Mode=OneWay}"
                                    Stretch="Uniform"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border
                            Width="6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="{x:Bind BurstAccentColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"
                            CornerRadius="12,0,0,12"
                            Opacity="0.8"
                            Visibility="{x:Bind IsBurstMemberVisualActive, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Border
                            CornerRadius="12"
                            BorderBrush="{x:Bind BurstAccentColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"
                            BorderThickness="0"
                            Opacity="0.75"
                            Visibility="{x:Bind IsBurstMemberVisualActive, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Button
                            Margin="0,0,0,0"
                            Padding="20,20"
                            Opacity="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Click="BurstToggleButton_Click"
                            Visibility="{x:Bind IsBurstFoldButtonVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="4" Opacity=".8">
                                <ContentControl Content="fold" ContentTemplate="{StaticResource FoldIconTemplate}"/>
                                <TextBlock
                                    Text="{x:Bind BurstBadgeText, Mode=OneWay}"
                            FontSize="12"
                           
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Border
                            Padding="30,10"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,40"
                            VerticalAlignment="Bottom"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{x:Bind IsBurstInlineBadgeVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="4" Opacity=".8">
                                <ContentControl Content="fold" ContentTemplate="{StaticResource FoldIconTemplate}"/>
                                <TextBlock
                                    Text="{x:Bind BurstOrdinalText, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <FontIcon
                            Glyph="&#xEB90;"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Visibility="{x:Bind IsThumbnailFailed, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <!-- 格式标签显示  Background="#CC000000"-->
                        <Border
                            Margin="8,8,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{ThemeResource SmokeFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="6,3"
                            Visibility="{x:Bind FormatTags.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <!-- 图标 -->
                                <FontIcon
                                    Glyph="&#xF156;"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Foreground="White"
                                    Margin="0,0,4,0"/>
                                
                                <!-- 格式标签 -->
                                <ItemsControl ItemsSource="{x:Bind FormatTags, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:FormatTag">
                                            <StackPanel Orientation="Horizontal">
                                                <Border
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="2,0,2,0">
                                                    <TextBlock
                                                        Text="{x:Bind Format}"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="White"/>
                                                </Border>
                                                <Border
                                                    Width="1"
                                                    Background="White"
                                                    Opacity="0.3"
                                                    Margin="3,0,2,0"
                                                    Visibility="{x:Bind IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        
                        <Grid
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Visibility="{x:Bind IsPendingDelete, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.Resources>
                                <LinearGradientBrush x:Key="DeleteGradient" StartPoint="0.658,0.321" EndPoint="-0.359,1.315">
                                    <GradientStop Offset="0" Color="#c23c49"/>
                                    <GradientStop Offset="1" Color="#ff99a4"/>
                                    
                                </LinearGradientBrush>
                            </Grid.Resources>
                            <!--<GradientStop Offset="0" Color="#850303"/>
                            <GradientStop Offset="1" Color="#e02f2f"/> -->
                            <!-- 第一个 path：带圆角的三角形（渐变填充） -->
                            <Path
                                Width="50"
                                Height="50"
                                Stretch="Uniform"
                                Fill="{StaticResource DeleteGradient}"
                                Data="M50,50 L3.5,50 A3.5,3.5,0,0,1,0,46.5 L0,0 L50,50 Z"/>
                            
                            <!-- 第二个 path：红色三角形 -->
                            <Path
                                Width="50"
                                Height="50"
                                Stretch="Uniform"
                                Fill="#272923"
                                Data="M50,0 L0,0 L50,50 Z"/>
                        </Grid>
                        
                        <Border
                            x:Name="RatingHost"
                            CanDrag="False"
                            MaxWidth="160"
                            MinWidth="96"
                            Height="26"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Margin="16,0,16,8"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            CornerRadius="10">
                            <controls:ShimmerControl IsLoading="{x:Bind IsRatingLoading, Mode=OneWay}">
                                <controls:ShimmerControl.Content>
                                    <Grid>
                                        <RatingControl
                                            CanDrag="False"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Value="{x:Bind RatingValue, Mode=TwoWay}"
                                            IsReadOnly="{x:Bind IsCollapsedBurstCover, Mode=OneWay}"
                                            IsClearEnabled="{x:Bind CanEditGridRating, Mode=OneWay}"
                                            MaxRating="5"
                                            Loaded="RatingControl_Loaded"/>
                                    </Grid>
                                </controls:ShimmerControl.Content>
                            </controls:ShimmerControl>
                        </Border>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="UseSystemFocusVisuals" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridViewItem">
                                <Grid x:Name="ContentBorder"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      CornerRadius="8">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal"/>
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Target="ContentBorder.Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                    <Setter Target="SelectionBorder.BorderThickness" Value="3"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PointerOverSelected">
                                                <VisualState.Setters>
                                                    <Setter Target="ContentBorder.Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                                                    <Setter Target="SelectionBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                    <Setter Target="SelectionBorder.BorderThickness" Value="3"/>
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    
                                    <ContentPresenter 
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Margin="{TemplateBinding Padding}"/>
                                    
                                    <Border x:Name="SelectionBorder"
                                            CornerRadius="8"
                                            BorderThickness="0"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerTransitions>
                <TransitionCollection/>
            </GridView.ItemContainerTransitions>
        </GridView>

        <ContentPresenter
            x:Name="ViewerContainer"
           
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="0"
            Grid.RowSpan="3"/>
    </Grid>
</Page>
