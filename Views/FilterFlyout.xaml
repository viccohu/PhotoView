    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10,0,16,0" Spacing="8" HorizontalAlignment="Stretch">
            <TextBlock Text="类型" Style="{ThemeResource BodyTextBlockStyle}" Margin="10,0"/>

            <StackPanel HorizontalAlignment="Stretch">
                <ToggleButton
                    x:Name="ImageFilterButton"
                    Style="{StaticResource FilterChipToggleButtonStyle}"
                    Checked="ImageFilterButton_Checked"
                    Unchecked="ImageFilterButton_Unchecked">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ContentControl ContentTemplate="{StaticResource PictureFileIconTemplate}"/>
                        <TextBlock Text="照片" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton
                    x:Name="RawFilterButton"
                    Style="{StaticResource FilterChipToggleButtonStyle}"
                    FontSize="14"
                    Checked="RawFilterButton_Checked"
                    Unchecked="RawFilterButton_Unchecked">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ContentControl ContentTemplate="{StaticResource RawFileIconTemplate}"/>
                        <TextBlock Text="数字底片" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <Border
                    Margin="10,0,10,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"/>

                <ToggleButton
                    x:Name="PendingDeleteFilterButton"
                    Style="{StaticResource FilterChipToggleButtonStyle}"
                    Checked="PendingDeleteFilterButton_Checked"
                    Unchecked="PendingDeleteFilterButton_Unchecked">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ContentControl ContentTemplate="{StaticResource DeleteFileIconTemplate}"/>
                        <TextBlock Text="预删除" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <Border
                    Margin="10,0,10,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"/>

                <ToggleButton
                    x:Name="BurstFilterButton"
                    Style="{StaticResource FilterChipToggleButtonStyle}"
                    Checked="BurstFilterButton_Checked"
                    Unchecked="BurstFilterButton_Unchecked"
                    Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ContentControl ContentTemplate="{StaticResource BurstFileIconTemplate}"/>
                        <TextBlock Text="连拍" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

        <StackPanel Grid.Column="2" Margin="16,0,20,0" Spacing="12" HorizontalAlignment="Left">
            <TextBlock Text="评级" Style="{ThemeResource BodyTextBlockStyle}"/>

            <StackPanel Spacing="4">
                <TextBlock Text="模式" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                <StackPanel x:Name="RatingModeButtonsPanel" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Stretch"/>
            </StackPanel>
            <Border
                Margin="0,6,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"/>
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="条件" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        <ComboBox x:Name="RatingConditionComboBox" >
                            <ComboBoxItem Tag="GreaterOrEqual" Content="&gt;="/>
                            <ComboBoxItem Tag="Equals" Content="="/>
                            <ComboBoxItem Tag="LessOrEqual" Content="&lt;="/>
                        </ComboBox>
                    </StackPanel>
                          
                    <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Left">
                        <TextBlock Text="星级" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        <RatingControl
                            x:Name="RatingStarsControl"
                            IsClearEnabled="True"
                            MaxRating="5"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
