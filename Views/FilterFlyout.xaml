<UserControl
    x:Class="PhotoView.Views.FilterFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:PhotoView.Converters"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="180"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto" MinWidth="240"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 文件类型筛选 -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="8">
            <TextBlock Text="文件类型" Style="{ThemeResource BodyTextBlockStyle}"/>
            <StackPanel x:Name="FileTypeButtonsPanel" Spacing="4">
                <ToggleButton x:Name="ImageFilterButton" Content="图片" Checked="ImageFilterButton_Checked" Unchecked="ImageFilterButton_Unchecked"/>
                <ToggleButton x:Name="RawFilterButton" Content="RAW" Checked="RawFilterButton_Checked" Unchecked="RawFilterButton_Unchecked"/>
            </StackPanel>
            <ToggleButton 
                x:Name="PendingDeleteFilterButton"
                Content="删除预选"
                Margin="0,8,0,0"
                Checked="PendingDeleteFilterButton_Checked"
                Unchecked="PendingDeleteFilterButton_Unchecked"/>
        </StackPanel>

        <!-- 分隔线 -->
        <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

        <!-- 评级筛选 -->
        <StackPanel Grid.Column="2" Margin="12,0,0,0" Spacing="12">
            <TextBlock Text="评级筛选" Style="{ThemeResource BodyTextBlockStyle}"/>

            <!-- 评级模式 - ToggleButton -->
            <StackPanel Spacing="4">
                <TextBlock Text="模式" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                <StackPanel x:Name="RatingModeButtonsPanel" Orientation="Horizontal" Spacing="4"/>
            </StackPanel>

            <!-- 评级条件 -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel Spacing="4" Width="100">
                        <TextBlock Text="条件" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        <ComboBox x:Name="RatingConditionComboBox">
                            <ComboBoxItem Tag="GreaterOrEqual" Content="≥"/>
                            <ComboBoxItem Tag="Equals" Content="="/>
                            <ComboBoxItem Tag="LessOrEqual" Content="≤"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="星级" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        <RatingControl 
                            x:Name="RatingStarsControl" 
                            IsClearEnabled="True" 
                            MaxRating="5"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
