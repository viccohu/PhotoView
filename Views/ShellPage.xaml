<Page
    x:Class="PhotoView.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:PhotoView.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:PhotoView.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="titleBar"
            Grid.Row="0"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="False"
            Title="PhotoView"
            >
            
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/WindowIcon.png" />
            </TitleBar.IconSource>

        </TitleBar>

        <NavigationView
            x:Name="NavigationViewControl"
            Grid.Row="1"
            AlwaysShowHeader="False"
            Canvas.ZIndex="0"
            IsSettingsVisible="True"
            IsBackButtonVisible="Collapsed"
            ItemInvoked="NavigationViewControl_ItemInvoked"
            CompactPaneLength="48"
            OpenPaneLength="320"
            PaneDisplayMode="Top"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=TwoWay}">
            <NavigationView.MenuItems>

                <NavigationViewItem
                    x:Name="MainNavigationItem"
                    x:Uid="Shell_Main"
                    helpers:NavigationHelper.NavigateTo="PhotoView.ViewModels.MainViewModel" />
                <NavigationViewItem
                    x:Name="PreviewNavigationItem"
                    x:Uid="Shell_Collect"
                    helpers:NavigationHelper.NavigateTo="PhotoView.ViewModels.CollectViewModel" />

            </NavigationView.MenuItems>

            <Grid Margin="0,0,0,0">
                <Frame x:Name="NavigationFrame" CacheSize="2" />
            </Grid>
        </NavigationView>

        <ContentControl
            x:Name="ShellToolbarHost"
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,7,68,0"
            Canvas.ZIndex="10"/>
    </Grid>
</Page>
