<Page
    x:Class="PhotoView.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:PhotoView.Helpers"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    xmlns:nav="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        
        <!-- 设置项卡片样式 -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
        
        <!-- 标题文本样式 -->
        <Style x:Key="SettingsTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
        </Style>
        
        <!-- 描述文本样式 -->
        <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
        
        <!-- 分组标题样式 -->
        <Style x:Key="SettingsGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>
        
        <!-- 页面标题样式 -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Page.Resources>
    
    <ScrollViewer Padding="0,0">
        <StackPanel MaxWidth="1064">
            <!-- 页面标题 -->
            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}"/>
            
            <!-- 外观和行为组 -->
            <TextBlock Text="Appearance &amp; behavior" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            
            <!-- 主题设置卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE790;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="App theme" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock Text="Select which app theme to display" Style="{StaticResource SettingsDescriptionStyle}"/>
                    </StackPanel>
                    
                    <!-- 主题选择器 -->
                    <ComboBox 
                        x:Name="themeMode"
                        Grid.Column="2" 
                        Width="140"
                        VerticalAlignment="Center"
                        SelectionChanged="themeMode_SelectionChanged">
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                        <ComboBoxItem Content="Use system setting" Tag="Default" />
                    </ComboBox>
                </Grid>
            </Border>
            
            <!-- 导航样式设置卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE71B;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Navigation style" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock Text="Choose how the app navigation is displayed" Style="{StaticResource SettingsDescriptionStyle}"/>
                    </StackPanel>
                    
                    <!-- 导航选择器 -->
                    <ComboBox 
                        x:Name="navigationLocation"
                        Grid.Column="2" 
                        Width="140"
                        VerticalAlignment="Center"
                        SelectionChanged="navigationLocation_SelectionChanged">
                        <ComboBoxItem Content="Top" Tag="Top" />
                        <ComboBoxItem Content="Left" Tag="Left" />
                    </ComboBox>
                </Grid>
            </Border>
            
            <!-- 性能设置组 -->
            <TextBlock Text="Performance" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            
            <!-- 缩略图缓存设置卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE7B5;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Thumbnail cache" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock Text="Cache thumbnails for faster loading" Style="{StaticResource SettingsDescriptionStyle}"/>
                    </StackPanel>
                    
                    <!-- 开关 -->
                    <ToggleSwitch 
                        Grid.Column="2" 
                        IsOn="True"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- 并发加载数设置卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE8A9;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Concurrent loaders" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock Text="Number of thumbnails to load at the same time" Style="{StaticResource SettingsDescriptionStyle}"/>
                    </StackPanel>
                    
                    <!-- 选择器 -->
                    <ComboBox 
                        Grid.Column="2" 
                        Width="100"
                        VerticalAlignment="Center">
                        <ComboBoxItem>4</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">8</ComboBoxItem>
                        <ComboBoxItem>16</ComboBoxItem>
                        <ComboBoxItem>32</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </Border>
            
            <!-- 显示设置组 -->
            <TextBlock Text="Display" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            
            <!-- 默认缩略图大小设置卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE7B8;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Default thumbnail size" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock Text="Set the default thumbnail display size" Style="{StaticResource SettingsDescriptionStyle}"/>
                    </StackPanel>
                    
                    <!-- 选择器 -->
                    <ComboBox 
                        Grid.Column="2" 
                        Width="100"
                        VerticalAlignment="Center">
                        <ComboBoxItem>Small</ComboBoxItem>
                        <ComboBoxItem IsSelected="True">Medium</ComboBoxItem>
                        <ComboBoxItem>Large</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </Border>
            
            <!-- 关于组 -->
            <TextBlock Text="About" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            
            <!-- 版本信息卡片 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标 -->
                    <FontIcon 
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE946;"
                        FontSize="20"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 标题和描述 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Uid="Settings_About" Style="{StaticResource SettingsTitleStyle}"/>
                        <TextBlock x:Uid="Settings_AboutDescription" Style="{StaticResource SettingsDescriptionStyle}" Margin="0,4,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" Style="{StaticResource SettingsDescriptionStyle}" Margin="0,4,0,0"/>
                        <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" Margin="0,8,0,0" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 底部间距 -->
            <Border Height="24"/>
        </StackPanel>
    </ScrollViewer>
</Page>