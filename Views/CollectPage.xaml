                                Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                Stretch="Uniform"/>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Column="2" ColumnSpacing="8" Width="220" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="ZoomValueButton"
                            Content="100%"
                            Width="80"
                            Click="ZoomValueButton_Click"/>

                        <Slider
                            x:Name="ZoomSlider"
                            Grid.Column="1"
                            Minimum="10"
                            Maximum="800"
                            Value="100"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    </Grid>

                </Grid>
            </Border>

            <Border
                x:Name="ThumbnailStripHost"
                Grid.Row="2"
                Grid.Column="0"
                Height="135"
                Padding="6,0,6,0"
                Margin="0,0,6,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="0,0,8,8">
                <ListView
                    x:Name="PreviewThumbnailGridView"
                    ItemsSource="{x:Bind ViewModel.Images}"
                    SelectionMode="Extended"
                    SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=OneWay}"
                    SelectionChanged="PreviewThumbnailGridView_SelectionChanged"
                    ContainerContentChanging="PreviewThumbnailGridView_ContainerContentChanging"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollMode="Enabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.ZoomMode="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ImageFileInfo">
                            <Grid
                                Width="142"
                                Height="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource ThumbnailItemHeightConverter}}"
                                Tag="{x:Bind}">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid RowSpacing="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="25"/>
                                        </Grid.RowDefinitions>
                                        <Grid
                                            Grid.Row="0"
                                            Margin="0"
                                            Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Image
                                                Source="{x:Bind Thumbnail, Mode=OneWay}"
                                                Stretch="Uniform"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                            <FontIcon
                                                Glyph="&#xEB90;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="22"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind IsThumbnailFailed, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <Border
                                                Padding="6,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="0,4,0,0"
                                                Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                                CornerRadius="4"
