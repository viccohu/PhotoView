<Page
    x:Class="PhotoView.Views.CollectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:controls="using:PhotoView.Controls"
    xmlns:local="using:PhotoView.Views"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:BooleanToDoubleConverter x:Key="ThumbnailItemHeightConverter" TrueValue="80" FalseValue="120"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <converters:NodeTypeToIconConverter x:Key="NodeTypeToIconConverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <SolidColorBrush x:Key="CollectToggleUncheckedForegroundBrush" Color="{ThemeResource TextFillColorPrimary}"/>
        <SolidColorBrush x:Key="CollectToggleCheckedForegroundBrush" Color="{ThemeResource TextOnAccentFillColorPrimary}"/>
        <Style x:Key="DualModeToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Column="1"
            Margin="4,6,0,6 "
            RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,6,0">
                <Border
                    x:Name="PreviewCanvasHost"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8,8,0,0"
                    Visibility="{x:Bind ViewModel.IsDualPageMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <controls:PreviewImageCanvasControl
                        x:Name="PreviewCanvas"
                        CurrentImage="{x:Bind ViewModel.SelectedImage, Mode=OneWay}"/>
                </Border>

                <Grid
                    x:Name="DualPreviewHost"
                    ColumnSpacing="2"
                    Visibility="{x:Bind ViewModel.IsDualPageMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="LeftPreviewHost"
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8,0,0,0"
                        Tapped="LeftPreviewHost_Tapped">
                        <controls:PreviewImageCanvasControl
                            x:Name="LeftPreviewCanvas"
                            CurrentImage="{x:Bind ViewModel.LeftPageImage, Mode=OneWay}"/>
                    </Border>

                    <Border
                        x:Name="RightPreviewHost"
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="0,8,0,0"
                        Tapped="RightPreviewHost_Tapped">
                        <controls:PreviewImageCanvasControl
                            x:Name="RightPreviewCanvas"
                            CurrentImage="{x:Bind ViewModel.RightPageImage, Mode=OneWay}"/>
                    </Border>
                </Grid>
            </Grid>

            <Border
                x:Name="PreviewInfoDrawer"
                Grid.Row="0"
                Grid.RowSpan="4"
                Grid.Column="1"
                Width="340"
                Margin="0,0,0,0"
                Padding="0,6,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0"
                CornerRadius="8,0,0,8"
                Visibility="Collapsed">
                <controls:ImageInfoPanelControl ViewModel="{x:Bind PreviewInfoViewModel, Mode=OneWay}"/>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="8,4,8,4"
                Margin="0,0,6,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="0">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                        <ToggleButton
                            x:Name="ThumbnailSizeToggleButton"
                            IsChecked="{x:Bind ViewModel.IsThumbnailStripCollapsed, Mode=TwoWay}"
                            Checked="CustomIconToggleButton_CheckedChanged"
                            Unchecked="CustomIconToggleButton_CheckedChanged">
                            <ContentControl
                                Content="{ThemeResource TextFillColorPrimaryBrush}"
                                ContentTemplate="{StaticResource ThumbnailSizeIconTemplate}"/>
                        </ToggleButton>
                        <ToggleButton
                            x:Name="InfoDrawerToggleButton"
                            IsChecked="{x:Bind ViewModel.IsInfoDrawerOpen, Mode=TwoWay}">
                            <FontIcon Glyph="&#xE946;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="18"/>
                        </ToggleButton>
                        <ToggleButton
                            x:Name="DualPageToggleButton"
                            IsChecked="{x:Bind ViewModel.IsDualPageMode, Mode=TwoWay}"
                            Click="DualPageToggleButton_Click"
                            Checked="CustomIconToggleButton_CheckedChanged"
                            Unchecked="CustomIconToggleButton_CheckedChanged">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ContentControl
                                    Content="{ThemeResource TextFillColorPrimaryBrush}"
                                    ContentTemplate="{StaticResource DualPageIconTemplate}"/>
                                
                            </StackPanel>
                        </ToggleButton>
                        <Border
                            Padding="2"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Visibility="{x:Bind ViewModel.IsDualPageMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <ToggleButton
                                    x:Name="CompareModeToggleButton"
                                    Style="{StaticResource DualModeToggleStyle}"
                                    Click="CompareModeToggleButton_Click"
                                    Checked="CustomIconToggleButton_CheckedChanged"
                                    CornerRadius="2,0,0,2"
                                    Unchecked="CustomIconToggleButton_CheckedChanged">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ContentControl
                                            Content="{ThemeResource TextFillColorPrimaryBrush}"
                                            ContentTemplate="{StaticResource CompareIconTemplate}"/>
                                        <TextBlock x:Uid="CollectPage_Compare" Text="对照"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton
                                    x:Name="ContinuousModeToggleButton"
                                    Style="{StaticResource DualModeToggleStyle}"
                                    Click="ContinuousModeToggleButton_Click"
                                    Checked="CustomIconToggleButton_CheckedChanged"
                                     CornerRadius="0,2,2,0"
                                    Unchecked="CustomIconToggleButton_CheckedChanged">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ContentControl
                                            Content="{ThemeResource TextFillColorPrimaryBrush}"
                                            ContentTemplate="{StaticResource ContinuousIconTemplate}"/>
                                        <TextBlock x:Uid="CollectPage_Continuous" Text="连续"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        
                        <Button x:Name="FlipHorizontalButton" Click="FlipPreviewHorizontal_Click">
                            <ContentControl
                                Content="{ThemeResource TextFillColorPrimaryBrush}"
                                ContentTemplate="{StaticResource FlipHorizontalIconTemplate}"/>
                        </Button>
                        <Button x:Name="RotatePreviewButton" Click="RotatePreview_Click">
                            <FontIcon Glyph="&#xE7AD;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="18"/>
                        </Button>
                        <Button x:Name="FlipVerticalButton" Click="FlipPreviewVertical_Click">
                            <ContentControl
                                Content="{ThemeResource TextFillColorPrimaryBrush}"
                                ContentTemplate="{StaticResource FlipVerticalIconTemplate}"/>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Column="2" ColumnSpacing="6" Width="280" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="ZoomValueButton"
                            Content="100%"
                            Width="90"
                           HorizontalContentAlignment="Left"
                            Click="ZoomValueButton_Click"/>

                        <Button
                            Grid.Column="1"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Click="ZoomOutButton_Click"
                            CornerRadius="2"
                            x:Name="ZoomOutButton">
                            <FontIcon Glyph="&#xE71F;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                        </Button>

                        <Slider
                            x:Name="ZoomSlider"
                            Grid.Column="2"
                            Minimum="10"
                            Maximum="800"
                            Value="100"
                            ValueChanged="ZoomSlider_ValueChanged"/>

                        <Button
                            Grid.Column="3"
                            Width="28"
                            Height="28"
                            Padding="0"
                            CornerRadius="2"
                            Click="ZoomInButton_Click"
                            x:Name="ZoomInButton">
                            <FontIcon Glyph="&#xE8A3;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                        </Button>
                    </Grid>

                </Grid>
            </Border>

            <Border
                x:Name="ThumbnailStripHost"
                Grid.Row="2"
                Grid.Column="0"
                Height="135"
                Padding="6,0,6,0"
                Margin="0,0,6,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="0,0,8,8">
                <ListView
                    x:Name="PreviewThumbnailGridView"
                    ItemsSource="{x:Bind ViewModel.Images}"
                    SelectionMode="Extended"
                    SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=OneWay}"
                    CanDragItems="True"
                    CanReorderItems="False"
                    SelectionChanged="PreviewThumbnailGridView_SelectionChanged"
                    DragItemsStarting="PreviewThumbnailGridView_DragItemsStarting"
                    ContainerContentChanging="PreviewThumbnailGridView_ContainerContentChanging"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollMode="Enabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.ZoomMode="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ImageFileInfo">
                            <Grid
                                Width="142"
                                Height="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource ThumbnailItemHeightConverter}}"
                                Tag="{x:Bind}"
                                PointerPressed="PreviewThumbnailItem_PointerPressed">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid RowSpacing="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition Height="25"/>
                                        </Grid.RowDefinitions>
                                        <Grid
                                            Grid.Row="0"
                                            Margin="0"
                                            Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Image
                                                Source="{x:Bind Thumbnail, Mode=OneWay}"
                                                Stretch="Uniform"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                            <FontIcon
                                                Glyph="&#xEB90;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="22"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind IsThumbnailFailed, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <Border
                                                Padding="10,3,6,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="0,6,0,0"
                                                Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Visibility="{x:Bind FormatTags.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <FontIcon
                                                        Glyph="&#xF156;"
                                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                        FontSize="12"
                                                        Foreground="White"
                                                        Margin="0,0,4,0"/>
                                                    <ItemsControl ItemsSource="{x:Bind FormatTags, Mode=OneWay}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:FormatTag">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border
                                                                        Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                                                        CornerRadius="4"
                                                                        Padding="4,1"
                                                                        Margin="2,0,2,0">
                                                                        <TextBlock
                                                                            Text="{x:Bind Format}"
                                                                            FontSize="10"
                                                                            Foreground="White"/>
                                                                    </Border>
                                                                    <Border
                                                                        Width="1"
                                                                        Background="White"
                                                                        Opacity="0.3"
                                                                        Margin="3,0,2,0"
                                                                        Visibility="{x:Bind IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Grid
                                            Grid.Row="0"
                                            Grid.RowSpan="3"
                                            Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="26"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="28"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel
                                                Grid.Row="0"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="10,5,10,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Visibility="{x:Bind FormatTags.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                                <FontIcon
                                                    Glyph="&#xF156;"
                                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                    FontSize="11"
                                                    Opacity="0.8"
                                                    VerticalAlignment="Center"/>
                                                <ItemsControl ItemsSource="{x:Bind FormatTags, Mode=OneWay}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:FormatTag">
                                                            <Border
                                                                Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                                                CornerRadius="4"
                                                                Padding="6,1"
                                                                Margin="0,0,6,0">
                                                                <TextBlock
                                                                    Text="{x:Bind Format}"
                                                                    FontSize="10"
                      
                                                                    Foreground="White"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Row="1"
                                                Text="{x:Bind ImageName}"
                                                FontSize="16"
                                                Margin="0,-10,0,0"
                                                
                                                TextTrimming="CharacterEllipsis"
                                                MaxWidth="120"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>

                                            <Border
                                                Grid.Row="2"
                                                Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                                CornerRadius="0,0,8,8"
                                                CanDrag="False">
                                                <RatingControl
                                                    Value="{x:Bind RatingValue, Mode=TwoWay}"
                                                    IsReadOnly="False"
                                                    IsClearEnabled="True"
                                                    MaxRating="5"
                                                    CanDrag="False"
                                                    FontSize="12"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Loaded="PreviewThumbnailRatingControl_Loaded"/>
                                            </Border>
                                        </Grid>
                                        <Rectangle
                                            Grid.Row="1"
                                            Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                            Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        <Border
                                            Grid.Row="2"
                                            Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                            CornerRadius="0,0,8,8"
                                            CanDrag="False"
                                            Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <RatingControl
                                                Value="{x:Bind RatingValue, Mode=TwoWay}"
                                                IsReadOnly="False"
                                                IsClearEnabled="True"
                                                MaxRating="5"
                                                CanDrag="False"
                                                FontSize="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Loaded="PreviewThumbnailRatingControl_Loaded"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border
                                    Width="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch"
                                    Background="{x:Bind BurstAccentColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"
                                    CornerRadius="8,0,0,8"
                                    Opacity="0.8"
                                    Visibility="{x:Bind IsBurstMember, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Grid Visibility="{x:Bind IsBurstMember, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border
                                        Padding="10,8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,25"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity=".8">
                                            <ContentControl Content="{ThemeResource TextFillColorPrimaryBrush}" ContentTemplate="{StaticResource BurstIconTemplate}"/>
                                            <TextBlock
                                                Text="{x:Bind BurstOrdinalText, Mode=OneWay}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Padding="4,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,6,8,0"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding DataContext.IsThumbnailStripCollapsed, ElementName=PreviewThumbnailGridView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity=".8">
                                            <ContentControl Content="{ThemeResource TextFillColorPrimaryBrush}" ContentTemplate="{StaticResource BurstIconTemplate}"/>
                                            <TextBlock
                                                Text="{x:Bind BurstOrdinalText, Mode=OneWay}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Grid
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Visibility="{x:Bind IsPendingDelete, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.Resources>
                                        <LinearGradientBrush x:Key="DeleteGradient" StartPoint="0.658,0.321" EndPoint="-0.359,1.315">
                                            <GradientStop Offset="0" Color="#c23c49"/>
                                            <GradientStop Offset="1" Color="#ff99a4"/>
                                        </LinearGradientBrush>
                                    </Grid.Resources>
                                    <Path
                                        Width="30"
                                        Height="30"
                                        Stretch="Uniform"
                                        Fill="{StaticResource DeleteGradient}"
                                        Data="M50,50 L3.5,50 A3.5,3.5,0,0,1,0,46.5 L0,0 L50,50 Z"/>
                                    <Path
                                        Width="30"
                                        Height="30"
                                        Stretch="Uniform"
                                        Fill="#303332"
                                        Data="M50,0 L0,0 L50,50 Z"/>
                                </Grid>
                                <Rectangle
                                    Margin="4,1,3,1"
                                    RadiusX="6"
                                    RadiusY="6"
                                    Opacity="0.6"
                                    IsHitTestVisible="False"
                                    Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                    StrokeThickness="3"
                                    StrokeDashArray="6,1"
                                    Visibility="{x:Bind IsSecondaryFocused, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="UseSystemFocusVisuals" Value="False"/>
                            <Setter Property="FocusVisualPrimaryThickness" Value="0"/>
                            <Setter Property="FocusVisualSecondaryThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Grid
                                            x:Name="ContentBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="8">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Target="ContentBorder.Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="Pressed"/>
                                                    <VisualState x:Name="Selected">
                                                        <VisualState.Setters>
                                                            <Setter Target="SelectionBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                            <Setter Target="SelectionBorder.BorderThickness" Value="3"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="PointerOverSelected">
                                                        <VisualState.Setters>
                                                            <Setter Target="ContentBorder.Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                                                            <Setter Target="SelectionBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                            <Setter Target="SelectionBorder.BorderThickness" Value="3"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="PressedSelected">
                                                        <VisualState.Setters>
                                                            <Setter Target="SelectionBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                            <Setter Target="SelectionBorder.BorderThickness" Value="3"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                </VisualStateGroup>
                                                <VisualStateGroup x:Name="FocusStates">
                                                    <VisualState x:Name="Focused"/>
                                                    <VisualState x:Name="Unfocused"/>
                                                    <VisualState x:Name="PointerFocused"/>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                            <ContentPresenter
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                Margin="{TemplateBinding Padding}"/>
                                            <Border
                                                x:Name="SelectionBorder"
                                                CornerRadius="8"
                                                BorderThickness="0"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </Border>

            <Grid Grid.Row="3" Grid.Column="0" />
        </Grid>
    </Grid>
</Page>



