                                Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                Stretch="Uniform"/>
                        </ToggleButton>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.72"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"/>
                    </Grid>

                    <Button Click="LoadPreview_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xF103;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" />
                            <TextBlock Text="载入" Style="{ThemeResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border
                x:Name="LoadDrawerTree"
                Grid.Row="1"
                Grid.Column="1"
                Padding="6"
                Background="Transparent"
                BorderBrush="{ThemeResource ControlAltFillColorTertiaryBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,12,0,0"
                CornerRadius="0">
                <TreeView
                    x:Name="PreviewFolderTreeView"
                    ItemsSource="{x:Bind ViewModel.FolderTree}"
                    Expanding="PreviewFolderTreeView_Expanding">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:FolderNode">
                            <TreeViewItem
                                ItemsSource="{x:Bind Children}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HasUnrealizedChildren="{x:Bind HasExpandableChildren, Mode=OneWay}"
                                DoubleTapped="PreviewFolderTreeItem_DoubleTapped"
                                RightTapped="PreviewFolderTreeItem_RightTapped">
                                <Grid Tag="{x:Bind}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FlyoutBase.AttachedFlyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem Text="�Ž�Ԥ��������" Icon="Add" Click="AddFolderToPreviewSource_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="固定到常用文件夹" Icon="Pin" Click="PinFolder_Click"/>
                                            <MenuFlyoutItem Text="取消固定" Icon="UnPin" Click="UnpinFolder_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="刷新外接设备" Icon="Refresh" Click="RefreshExternalDevices_Click"/>
                                        </MenuFlyout>
                                    </FlyoutBase.AttachedFlyout>
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="{Binding Converter={StaticResource NodeTypeToIconConverter}}"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Margin="0,0,6,0"/>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </Grid>

        <Grid
            Grid.Column="1"
            Margin="4,6,0,6 "
            RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Grid.Column="0"
                
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Margin="0,0,6,0"
                CornerRadius="8,8,0,0">
                <controls:PreviewImageCanvasControl
                    x:Name="PreviewCanvas"
                    CurrentImage="{x:Bind ViewModel.SelectedImage, Mode=OneWay}"/>
            </Border>

            <Border
                x:Name="PreviewInfoDrawer"
                Grid.Row="0"
                Grid.RowSpan="4"
                Grid.Column="1"
                Width="340"
                Margin="0,0,0,0"
                Padding="0,6,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0"
                CornerRadius="8,0,0,8"
                Visibility="{x:Bind ViewModel.IsInfoDrawerOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <controls:ImageInfoPanelControl ViewModel="{x:Bind PreviewInfoViewModel, Mode=OneWay}"/>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="8,4,8,4"
                Margin="0,0,6,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="0">
