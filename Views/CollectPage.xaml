<Page
    x:Class="PhotoView.Views.CollectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:controls="using:PhotoView.Controls"
    xmlns:local="using:PhotoView.Views"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:BooleanToDoubleConverter x:Key="ThumbnailItemHeightConverter" TrueValue="80" FalseValue="120"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <converters:NodeTypeToIconConverter x:Key="NodeTypeToIconConverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="LoadDrawerRoot"
            Grid.Column="0"
            Width="292"
            Margin="0,6,0,6"
            RowSpacing="0"
            HorizontalAlignment="Left"
            PointerEntered="LoadDrawerRoot_PointerEntered"
            PointerExited="LoadDrawerRoot_PointerExited">
