<Page
    x:Class="PhotoView.Views.CollectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    mc:Ignorable="d">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="12" HorizontalAlignment="Right">
            <Button x:Name="EditButton" Content="编辑">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="分享" Icon="Share"/>
                        <MenuFlyoutItem Text="复制" Icon="Copy"/>
                        <MenuFlyoutItem Text="删除" Icon="Delete"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="重命名"/>
                        <MenuFlyoutItem Text="选择"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <GridView 
            Grid.Row="1" 
            x:Name="ImageGridView" 
            ItemsSource="{x:Bind ViewModel.Images}"
            Padding="12">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ImageFileInfo">
                    <Border 
                        Margin="6"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <Grid>
                            <Image 
                                Source="{x:Bind ImageFile.Path}" 
                                Stretch="UniformToFill"
                                Width="200"
                                Height="150"/>
                            <Border 
                                Background="Transparent"
                                RightTapped="Image_RightTapped">
                                <FlyoutBase.AttachedFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="分享" Icon="Share" Click="Share_Click"/>
                                        <MenuFlyoutItem Text="保存" Icon="Save" Click="Save_Click"/>
                                        <MenuFlyoutItem Text="删除" Icon="Delete" Click="Delete_Click"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="调整大小"/>
                                        <MenuFlyoutItem Text="移动"/>
                                    </MenuFlyout>
                                </FlyoutBase.AttachedFlyout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid 
                        Orientation="Horizontal" 
                        MaximumRowsOrColumns="4"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</Page>
