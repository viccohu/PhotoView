<ContentDialog
    x:Class="PhotoView.Dialogs.DeleteConfirmDialog"
    x:Uid="DeleteConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="确认删除"
    SecondaryButtonText="取消"
    DefaultButton="Secondary"
    CornerRadius="12">

    <StackPanel Spacing="16">
        <TextBlock
            x:Name="ContentText"
            TextWrapping="Wrap"
            FontSize="14"/>

        <TextBlock
            x:Uid="DeleteConfirmDialog_SelectionHint"
            x:Name="SelectionHintText"
            Text="选择要删除的文件类型："
            FontSize="12"
            Opacity="0.7"/>

        <Border
            x:Name="BurstWarningHost"
            Padding="10,8"
            CornerRadius="8"
            Visibility="Collapsed">
            <TextBlock
                x:Name="BurstWarningText"
                TextWrapping="Wrap"
                FontSize="12"/>
        </Border>

        <StackPanel x:Name="ToggleButtonsPanel" Orientation="Horizontal" Spacing="8"/>

        <StackPanel x:Name="ProgressPanel" Spacing="8" Visibility="Collapsed">
            <ProgressBar
                x:Name="DeleteProgressBar"
                Height="4"
                Minimum="0"
                Maximum="100"
                Value="0"/>

            <TextBlock
                x:Name="ProgressText"
                FontSize="12"
                Opacity="0.7"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>
