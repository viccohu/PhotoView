<ContentDialog
    x:Class="PhotoView.Dialogs.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="导出"
    CloseButtonText="取消"
    PrimaryButtonText="开始导出"
    DefaultButton="Primary"
    CornerRadius="12">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1180</x:Double>
        <CornerRadius x:Key="ContentDialogCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    </ContentDialog.Resources>

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </ContentDialog.CloseButtonStyle>

    <StackPanel Width="550" MaxWidth="780" Spacing="18">

        <StackPanel Spacing="16">
            <TextBlock Text="选择要导出的文件类型和筛选条件" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleButton x:Name="ImageToggleButton" Width="140" Content="照片（JPG）"/>
                <ComboBox x:Name="ImageRatingComboBox" Width="100" PlaceholderText="星级" IsEnabled="False">
                    <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                    <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                    <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                    <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                    <ComboBoxItem Content="≥ 5 星" Tag="5"/>
                </ComboBox>
                <TextBox x:Name="ImageFolderTextBox" Width="140" PlaceholderText="文件夹名称" IsEnabled="False"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleButton x:Name="RawToggleButton" Width="140" Content="数字底片（RAW）"/>
                <ComboBox x:Name="RawRatingComboBox" Width="100" PlaceholderText="星级" IsEnabled="False">
                    <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                    <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                    <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                    <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                    <ComboBoxItem Content="≥ 5 星" Tag="5"/>
                </ComboBox>
                <TextBox x:Name="RawFolderTextBox" Width="140" PlaceholderText="文件夹名称" IsEnabled="False"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox x:Name="ExportPathTextBox" PlaceholderText="导出地址" Width="690"/>
                <Button x:Name="SelectFolderButton" Width="78" Content="📁"/>
            </StackPanel>

            <ProgressBar x:Name="ExportProgressBar" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>

            <TextBlock x:Name="StatusTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" Text=" "/>
        </StackPanel>

        <Border
            Padding="24,12"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <StackPanel Spacing="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
    
                        <TextBlock Text="重设大小" FontSize="18" FontWeight="SemiLight"/>
                       

                    <ToggleSwitch
                        x:Name="ResizeEnabledSwitch"
                        Grid.Column="1"
                        MinWidth="0"
                        OffContent=""
                        OnContent=""/>
                </Grid>

                <StackPanel x:Name="ResizeOptionsPanel" Spacing="16" Visibility="Collapsed">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <RadioButton x:Name="ResizePixelRadioButton" Content="像素" GroupName="ResizeMode" IsChecked="True"/>
                                <RadioButton x:Name="ResizePercentRadioButton" Content="百分比" GroupName="ResizeMode"/>
                            </StackPanel>

                            <TextBox x:Name="ResizeLongSideTextBox" Header="最长边 (px)" Text="2000" InputScope="Number"/>
                            <TextBox x:Name="ResizePercentTextBox" Header="百分比 (%)" Text="50" InputScope="Number" Visibility="Collapsed"/>
                        </StackPanel>

                        <ComboBox x:Name="ResizeFormatComboBox" Grid.Column="1" Header="文件类型" SelectedIndex="0">
                            <ComboBoxItem Content="JPG" Tag="JPG"/>
                            <ComboBoxItem Content="PNG" Tag="PNG"/>
                            <ComboBoxItem Content="TIF" Tag="TIF"/>
                        </ComboBox>

                        <ComboBox x:Name="ResizeFilterComboBox" Grid.Column="2" Header="缩放算法" SelectedIndex="0">
                            <ComboBoxItem Content="高质量" Tag="HighQuality"/>
                            <ComboBoxItem Content="均衡" Tag="Balanced"/>
                            <ComboBoxItem Content="快速" Tag="Fast"/>
                            <ComboBoxItem Content="锐利" Tag="Sharp"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="ResizeQualityTextBlock" Text="质量：90%（仅 JPG）"/>
                        <Slider x:Name="ResizeQualitySlider" Minimum="1" Maximum="100" Value="90" StepFrequency="1"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="当前：" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ResizePreviewCurrentTextBlock" Grid.Column="1" Text="无可预览照片"/>

                        <TextBlock Grid.Row="1" Text="新建：" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ResizePreviewNewTextBlock" Grid.Row="1" Grid.Column="1" Text="启用后显示"/>

                        <TextBlock x:Name="ResizeHintTextBlock" Grid.Row="2" Grid.ColumnSpan="2" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</ContentDialog>
