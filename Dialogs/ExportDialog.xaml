<ContentDialog
    x:Class="PhotoView.Dialogs.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="导出图片"
    CloseButtonText="取消"
    PrimaryButtonText="开始导出"
    DefaultButton="Primary">
    
    <StackPanel Spacing="16" MaxWidth="500">
        <TextBlock Text="选择要导出的文件类型和筛选条件" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
        
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleButton x:Name="ImageToggleButton" Width="80" Content="图片"/>
            <ComboBox x:Name="ImageRatingComboBox" Width="100" PlaceholderText="星级" IsEnabled="False">
                <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                <ComboBoxItem Content="≥ 5 星" Tag="5"/>
            </ComboBox>
            <TextBox x:Name="ImageFolderTextBox" Width="120" PlaceholderText="文件夹名称" IsEnabled="False"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleButton x:Name="RawToggleButton" Width="80" Content="RAW"/>
            <ComboBox x:Name="RawRatingComboBox" Width="100" PlaceholderText="星级" IsEnabled="False">
                <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                <ComboBoxItem Content="≥ 5 星" Tag="5"/>
            </ComboBox>
            <TextBox x:Name="RawFolderTextBox" Width="120" PlaceholderText="文件夹名称" IsEnabled="False"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBox x:Name="ExportPathTextBox" PlaceholderText="导出地址" Width="350"/>
            <Button x:Name="SelectFolderButton" Content="📁"/>
        </StackPanel>
        
        <ProgressBar x:Name="ExportProgressBar" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>
        
        <TextBlock x:Name="StatusTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" Text="准备导出"/>
    </StackPanel>
</ContentDialog>
