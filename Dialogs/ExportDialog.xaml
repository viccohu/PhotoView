<ContentDialog
    x:Class="PhotoView.Dialogs.ExportDialog"
    x:Uid="ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    CloseButtonText="取消"
    PrimaryButtonText="开始导出"
    DefaultButton="Primary"
    CornerRadius="12">

    <ContentDialog.Title>
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Uid="ExportDialog_Title"
                Text="导出"
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"/>

            <Border
                x:Name="FilteredScopeContainerBorder"
                Grid.Column="1"
                Margin="4,0,0,0"
                Padding="10,0"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock
                        x:Uid="ExportDialog_FilteredScope"
                        Text="按筛选结果导出"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        FontSize="12"
                        Opacity="0.78"
                        VerticalAlignment="Center"/>
                    <ToggleSwitch
                        x:Name="FilteredScopeToggleSwitch"
                        MinWidth="0"
                        OffContent=""
                        OnContent=""
                        VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ContentDialog.Title>

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1180</x:Double>
        <CornerRadius x:Key="ContentDialogCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
        <SolidColorBrush x:Key="ExportToggleUncheckedForegroundBrush" Color="{ThemeResource TextFillColorPrimary}"/>
        <SolidColorBrush x:Key="ExportToggleCheckedForegroundBrush" Color="{ThemeResource TextOnAccentFillColorPrimary}"/>
</ContentDialog.Resources>

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </ContentDialog.CloseButtonStyle>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Width="600" MaxWidth="650" Spacing="14">

            <StackPanel Spacing="14">
                <TextBlock
                    x:Uid="ExportDialog_SectionHint"
                    Text="选择要导出的文件类型和筛选条件"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    FontSize="12"
                    Opacity="0.7"
                    TextWrapping="Wrap"/>

                <Grid ColumnSpacing="6" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="ImageToggleButton" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ContentControl x:Name="ImageToggleIconControl" Content="{ThemeResource TextFillColorPrimaryBrush}" ContentTemplate="{StaticResource PictureFileIconTemplate}"/>
                                <TextBlock x:Uid="ExportDialog_Photo" Text="照片（JPG）" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ComboBox x:Uid="ExportDialog_ImageStarPlaceholder" x:Name="ImageRatingComboBox" Grid.Column="1" PlaceholderText="星级" IsEnabled="False" HorizontalAlignment="Stretch">
                            <ComboBoxItem x:Uid="ExportDialog_ImageRating1" Content="≥ 1 星" Tag="1"/>
                            <ComboBoxItem x:Uid="ExportDialog_ImageRating2" Content="≥ 2 星" Tag="2"/>
                            <ComboBoxItem x:Uid="ExportDialog_ImageRating3" Content="≥ 3 星" Tag="3"/>
                            <ComboBoxItem x:Uid="ExportDialog_ImageRating4" Content="≥ 4 星" Tag="4"/>
                            <ComboBoxItem x:Uid="ExportDialog_ImageRating5" Content="≥ 5 星" Tag="5"/>
                        </ComboBox>
                        <TextBox x:Uid="ExportDialog_FolderName" x:Name="ImageFolderTextBox" Grid.Column="2" PlaceholderText="文件夹名称" IsEnabled="False"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="RawToggleButton" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ContentControl x:Name="RawToggleIconControl" Content="{ThemeResource TextFillColorPrimaryBrush}" ContentTemplate="{StaticResource RawFileIconTemplate}"/>
                                <TextBlock x:Uid="ExportDialog_Raw" Text="数字底片（RAW）" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ComboBox x:Uid="ExportDialog_RawStarPlaceholder" x:Name="RawRatingComboBox" Grid.Column="1" PlaceholderText="星级" IsEnabled="False" HorizontalAlignment="Stretch">
                            <ComboBoxItem x:Uid="ExportDialog_RawRating1" Content="≥ 1 星" Tag="1"/>
                            <ComboBoxItem x:Uid="ExportDialog_RawRating2" Content="≥ 2 星" Tag="2"/>
                            <ComboBoxItem x:Uid="ExportDialog_RawRating3" Content="≥ 3 星" Tag="3"/>
                            <ComboBoxItem x:Uid="ExportDialog_RawRating4" Content="≥ 4 星" Tag="4"/>
                            <ComboBoxItem x:Uid="ExportDialog_RawRating5" Content="≥ 5 星" Tag="5"/>
                        </ComboBox>
                        <TextBox x:Name="RawFolderTextBox" Grid.Column="2" PlaceholderText="RAW" IsEnabled="False"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Uid="ExportDialog_ExportPath" x:Name="ExportPathTextBox" MinWidth="0" PlaceholderText="导出地址"/>
                        <Button x:Uid="ExportDialog_Browse" x:Name="SelectFolderButton" Grid.Column="1" MinWidth="92" Content="浏览"/>
                    </Grid>

                    <Border
                        Grid.Column="1"
                        Grid.RowSpan="3"
                        Padding="10,10,10,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock
                                    x:Uid="ExportDialog_Expected"
                                    Text="预计导出"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Opacity="0.72"/>
                                <TextBlock
                                    x:Name="ExportCountSummaryTextBlock"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="0 个文件"
                                    TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Spacing="6">
                                <Border
                                    Padding="8,4"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="6">
                                    <TextBlock
                                        x:Name="ExportImageCountTextBlock"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        HorizontalAlignment="Center"
                                        Text="JPG 0"/>
                                </Border>
                                <Border
                                    Padding="8,4"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="6">
                                    <TextBlock
                                        x:Name="ExportRawCountTextBlock"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        HorizontalAlignment="Center"
                                        Text="RAW 0"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <ProgressBar x:Name="ExportProgressBar" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>

                <TextBlock
                    x:Name="StatusTextBlock"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.7"
                    Text=" "
                    TextWrapping="Wrap"/>
            </StackPanel>

            <Border
                Padding="26,10"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="0">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Uid="ExportDialog_ResizeTitle" Text="重设大小" FontSize="18" FontWeight="SemiLight" VerticalAlignment="Center"/>

                        <ToggleSwitch
                            x:Name="ResizeEnabledSwitch"
                            Grid.Column="1"
                            MinWidth="0"
                            OffContent=""
                            OnContent=""/>
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>


                    <StackPanel x:Name="ResizeOptionsPanel" Spacing="14" Visibility="Collapsed" Margin="0,12,0,0">
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="95"/>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock x:Uid="ExportDialog_ResizeOptions" Text="缩放选项" VerticalAlignment="Center" Opacity="0.7"/>
                            <ComboBox x:Name="ResizeModeComboBox" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem x:Uid="ExportDialog_Pixel" Content="像素" Tag="Pixel"/>
                                <ComboBoxItem x:Uid="ExportDialog_Percent" Content="百分比" Tag="Percent"/>
                            </ComboBox>

                            <TextBlock x:Uid="ExportDialog_LongSidePixel" x:Name="ResizeInputHeaderTextBlock" Grid.Column="2" Text="长边尺寸（像素）" VerticalAlignment="Center" Opacity="0.7"/>
                            <Grid Grid.Column="3">
                                <TextBox x:Name="ResizeLongSideTextBox" Text="1920" InputScope="Number" />
                                <TextBox x:Name="ResizePercentTextBox" Text="100" InputScope="Number" Visibility="Collapsed" />
                            </Grid>

                            <TextBlock x:Uid="ExportDialog_ResizeAlgorithm" Grid.Column="4" Text="缩放算法" VerticalAlignment="Center" Opacity="0.7"/>
                            <ComboBox x:Name="ResizeFilterComboBox" Grid.Column="5" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem x:Uid="ExportDialog_HighQuality" Content="高质量" Tag="HighQuality"/>
                                <ComboBoxItem x:Uid="ExportDialog_Balanced" Content="均衡" Tag="Balanced"/>
                                <ComboBoxItem x:Uid="ExportDialog_Fast" Content="快速" Tag="Fast"/>
                                <ComboBoxItem x:Uid="ExportDialog_Sharp" Content="锐利" Tag="Sharp"/>
                            </ComboBox>

                            <TextBlock x:Uid="ExportDialog_FileFormat" Grid.Row="1" Text="文件格式" VerticalAlignment="Center" Opacity="0.7"/>
                            <ComboBox x:Name="ResizeFormatComboBox" Grid.Row="1" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="JPG" Tag="JPG"/>
                                <ComboBoxItem Content="PNG" Tag="PNG"/>
                                <ComboBoxItem Content="TIF" Tag="TIF"/>
                            </ComboBox>

                            <TextBlock x:Name="ResizeQualityTextBlock" Grid.Row="1" Grid.Column="2" Text="质量：100%" VerticalAlignment="Center" Opacity="0.7"/>
                            <Slider
                                x:Name="ResizeQualitySlider"
                                Grid.Row="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="3"
                                Minimum="10"
                                Maximum="100"
                                Value="90"
                                Width="200"
      
                                StepFrequency="10"
                                HorizontalAlignment="Left"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <Grid ColumnSpacing="8" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Uid="ExportDialog_Current" Text="当前：" FontWeight="SemiBold" VerticalAlignment="Top" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                            <TextBlock x:Name="ResizePreviewCurrentTextBlock" Grid.Column="1" Text="无可预览照片" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>

                            <TextBlock x:Uid="ExportDialog_New" Grid.Row="1" Text="新建：" FontWeight="SemiBold" VerticalAlignment="Top" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                            <TextBlock x:Name="ResizePreviewNewTextBlock" Grid.Row="1" Grid.Column="1" Text="启用后显示" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>

                            <TextBlock
                                x:Name="ResizeHintTextBlock"
                                Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.7"
                                Visibility="Collapsed"
                                TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>

