            </Viewbox>
        </DataTemplate>

        <DataTemplate x:Key="ExportRawFileIconTemplate">
            <Viewbox Width="20" Height="20">
                <Canvas Width="25" Height="25">
                    <shapes:Path Fill="{ThemeResource TextFillColorPrimaryBrush}" Data="m8.53,15.5s0,.07-.02.09-.05.05-.1.06c-.05.02-.12.03-.22.03-.1,0-.23,0-.4,0-.14,0-.25,0-.34,0-.08,0-.15-.02-.2-.04-.05-.02-.08-.04-.1-.07s-.04-.06-.05-.1l-.58-1.44c-.07-.16-.14-.31-.21-.43s-.14-.23-.22-.32-.18-.15-.28-.19c-.11-.04-.23-.06-.37-.06h-.41v2.46s-.01.06-.03.09c-.02.03-.06.05-.11.07-.05.02-.12.03-.2.04s-.19.01-.32.01-.23,0-.32-.01-.15-.02-.2-.04c-.05-.02-.09-.04-.11-.07-.02-.03-.03-.06-.03-.09v-5.87c0-.15.04-.25.11-.32.08-.06.17-.1.28-.1h1.68c.17,0,.31,0,.42,0,.11,0,.21.01.3.02.26.04.5.1.71.19.21.09.39.21.53.35.15.15.26.32.33.51s.12.43.12.68c0,.22-.03.41-.08.59-.06.18-.14.34-.24.48-.11.14-.24.26-.4.36-.16.1-.34.19-.54.25.1.05.19.1.27.17.09.07.17.15.24.24.08.1.15.2.21.33s.13.26.2.41l.55,1.27c.05.13.08.22.1.28.02.06.03.1.03.14Zm-1.7-4.39c0-.21-.05-.39-.15-.54-.1-.15-.26-.25-.48-.31-.07-.02-.14-.03-.23-.04s-.2-.01-.35-.01h-.59v1.83h.67c.19,0,.35-.02.49-.07.14-.04.26-.11.35-.19.09-.08.16-.18.21-.29.05-.11.07-.24.07-.38Z"/>
