<ContentDialog
    x:Class="PhotoView.Dialogs.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="导出"
    CloseButtonText="取消"
    PrimaryButtonText="开始导出"
    DefaultButton="Primary"
    CornerRadius="12">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1180</x:Double>
        <CornerRadius x:Key="ContentDialogCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    </ContentDialog.Resources>

    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </ContentDialog.CloseButtonStyle>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Width="720" MaxWidth="840" Spacing="14">

            <StackPanel Spacing="14">
                <TextBlock
                    Text="选择要导出的文件类型和筛选条件"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.7"
                    TextWrapping="Wrap"/>

                <Grid ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="112"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ToggleButton x:Name="ImageToggleButton" Content="照片（JPG）" HorizontalAlignment="Stretch"/>
                    <ComboBox x:Name="ImageRatingComboBox" Grid.Column="1" PlaceholderText="星级" IsEnabled="False" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                        <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                        <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                        <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                        <ComboBoxItem Content="≥ 5 星" Tag="5"/>
                    </ComboBox>
                    <TextBox x:Name="ImageFolderTextBox" Grid.Column="2" PlaceholderText="文件夹名称" IsEnabled="False"/>

                    <ToggleButton x:Name="RawToggleButton" Grid.Row="1" Content="数字底片（RAW）" HorizontalAlignment="Stretch"/>
                    <ComboBox x:Name="RawRatingComboBox" Grid.Row="1" Grid.Column="1" PlaceholderText="星级" IsEnabled="False" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="≥ 1 星" Tag="1"/>
                        <ComboBoxItem Content="≥ 2 星" Tag="2"/>
                        <ComboBoxItem Content="≥ 3 星" Tag="3"/>
                        <ComboBoxItem Content="≥ 4 星" Tag="4"/>
                        <ComboBoxItem Content="≥ 5 星" Tag="5"/>
                    </ComboBox>
                    <TextBox x:Name="RawFolderTextBox" Grid.Row="1" Grid.Column="2" PlaceholderText="RAW" IsEnabled="False"/>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ExportPathTextBox" MinWidth="0" PlaceholderText="导出地址"/>
                    <Button x:Name="SelectFolderButton" Grid.Column="1" MinWidth="92" Content="浏览"/>
                </Grid>

                <ProgressBar x:Name="ExportProgressBar" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>

                <TextBlock
                    x:Name="StatusTextBlock"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Opacity="0.7"
                    Text=" "
                    TextWrapping="Wrap"/>
            </StackPanel>

            <Border
                Padding="26,10"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="0">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="重设大小" FontSize="18" FontWeight="SemiLight" VerticalAlignment="Center"/>

                        <ToggleSwitch
                            x:Name="ResizeEnabledSwitch"
                            Grid.Column="1"
                            MinWidth="0"
                            OffContent=""
                            OnContent=""/>
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>


                    <StackPanel x:Name="ResizeOptionsPanel" Spacing="14" Visibility="Collapsed" Margin="0,12,0,0">
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="108"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="124"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="缩放选项" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ResizeModeComboBox" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="像素" Tag="Pixel"/>
                                <ComboBoxItem Content="百分比" Tag="Percent"/>
                            </ComboBox>

                            <TextBlock x:Name="ResizeInputHeaderTextBlock" Grid.Column="2" Text="缩放输入框（像素）" VerticalAlignment="Center"/>
                            <Grid Grid.Column="3">
                                <TextBox x:Name="ResizeLongSideTextBox" Text="1920" InputScope="Number"/>
                                <TextBox x:Name="ResizePercentTextBox" Text="100" InputScope="Number" Visibility="Collapsed"/>
                            </Grid>

                            <TextBlock Grid.Column="4" Text="缩放算法" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ResizeFilterComboBox" Grid.Column="5" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="高质量" Tag="HighQuality"/>
                                <ComboBoxItem Content="均衡" Tag="Balanced"/>
                                <ComboBoxItem Content="快速" Tag="Fast"/>
                                <ComboBoxItem Content="锐利" Tag="Sharp"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="文件格式" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ResizeFormatComboBox" Grid.Row="1" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="JPG" Tag="JPG"/>
                                <ComboBoxItem Content="PNG" Tag="PNG"/>
                                <ComboBoxItem Content="TIF" Tag="TIF"/>
                            </ComboBox>

                            <TextBlock x:Name="ResizeQualityTextBlock" Grid.Row="1" Grid.Column="2" Text="质量：90%（仅 JPG）" VerticalAlignment="Center"/>
                            <Slider
                                x:Name="ResizeQualitySlider"
                                Grid.Row="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="3"
                                Minimum="10"
                                Maximum="100"
                                Value="90"
                                StepFrequency="10"
                                HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <Grid ColumnSpacing="8" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="当前：" FontWeight="SemiBold" VerticalAlignment="Top" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                            <TextBlock x:Name="ResizePreviewCurrentTextBlock" Grid.Column="1" Text="无可预览照片" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>

                            <TextBlock Grid.Row="1" Text="新建：" FontWeight="SemiBold" VerticalAlignment="Top" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                            <TextBlock x:Name="ResizePreviewNewTextBlock" Grid.Row="1" Grid.Column="1" Text="启用后显示" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>

                            <TextBlock
                                x:Name="ResizeHintTextBlock"
                                Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.7"
                                Visibility="Collapsed"
                                TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
