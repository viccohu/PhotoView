<ContentDialog
    x:Class="PhotoView.Dialogs.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    mc:Ignorable="d"
    Title="导出"
    CloseButtonText="取消"
    PrimaryButtonText="开始导出"
    DefaultButton="Primary"
    CornerRadius="12">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1180</x:Double>
        <CornerRadius x:Key="ContentDialogCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>

