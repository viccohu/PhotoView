<UserControl
    x:Class="PhotoView.Controls.CollectSourcePane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="PaneGhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="12"
        Width="300"
        Background="Transparent">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="80" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Style="{ThemeResource BodyTextBlockStyle}">
                <Run Text="载入区" />
                <Run Text="{x:Bind Subtitle, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </TextBlock>

            <ItemsControl
                Grid.Row="1"
                ItemsSource="{x:Bind SourceItems, Mode=OneWay}"
                Visibility="{x:Bind HasSourceItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,4"
                            Padding="8,8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding DisplayName}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    FontSize="16" />
                                <Button
                                    Grid.Column="1"
                                    Tag="{Binding}"
                                    Click="RemoveSourceButton_Click"
                                    Style="{StaticResource PaneGhostButtonStyle}">
                                    <FontIcon
                                        Glyph="&#xE711;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="12" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ToggleButton
                     Grid.Column="0"
                     Content="{x:Bind ToggleOptionText, Mode=OneWay}"
                     IsChecked="{x:Bind ToggleOptionValue, Mode=TwoWay}"
                     Checked="ToggleOptionButton_CheckedChanged"
                     Unchecked="ToggleOptionButton_CheckedChanged"
                     Visibility="{x:Bind IsToggleOptionVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
