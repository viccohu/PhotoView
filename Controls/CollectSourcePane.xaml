<UserControl
    x:Class="PhotoView.Controls.CollectSourcePane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PhotoView.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="PaneGhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style x:Key="PaneGhostToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="32" />
        </Style>
    </UserControl.Resources>

    <Border Width="300" Background="Transparent">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MinHeight="80" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock
                    x:Name="LoadFoldersTextBlock"
                    Style="{ThemeResource BodyTextBlockStyle}" />
                <TextBlock
                    Text="{x:Bind Subtitle, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}" />
            </StackPanel>

            <ItemsControl
                Grid.Row="1"
                ItemsSource="{x:Bind SourceItems, Mode=OneWay}"
                Visibility="{x:Bind HasSourceItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,4"
                            Padding="8,0"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding DisplayName}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    FontSize="16" />
                                <ToggleButton
                                    Grid.Column="1"
                                    Tag="{Binding}"
                                    Height="35"
                                    IsChecked="{Binding IncludeSubfolders, Mode=TwoWay}"
                                    Checked="SourceIncludeSubfoldersButton_CheckedChanged"
                                    Unchecked="SourceIncludeSubfoldersButton_CheckedChanged"
                                    Loaded="SourceIncludeSubfoldersButton_Loaded"
                                    Style="{StaticResource PaneGhostToggleButtonStyle}">
                                    <ContentControl
                                        Content="{ThemeResource TextFillColorPrimaryBrush}"
                                        ContentTemplate="{StaticResource SubFolderIconTemplate}" />
                                </ToggleButton>
                                <Button
                                    Grid.Column="2"
                                    Tag="{Binding}"
                                    Width="35"
                                    Height="35"
                                    Margin="6,0"
                                    Click="RemoveSourceButton_Click"
                                    Style="{StaticResource PaneGhostButtonStyle}">
                                    <FontIcon
                                        Glyph="&#xE711;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="12" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ToggleButton
                Grid.Row="2"
                IsChecked="{x:Bind ToggleOptionValue, Mode=TwoWay}"
                Checked="ToggleOptionButton_CheckedChanged"
                Unchecked="ToggleOptionButton_CheckedChanged"
                ToolTipService.ToolTip="{x:Bind ToggleOptionText, Mode=OneWay}"
                Visibility="{x:Bind IsToggleOptionVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ContentControl
                        Content="{ThemeResource TextFillColorPrimaryBrush}"
                        ContentTemplate="{StaticResource SubFolderIconTemplate}" />
                    <Rectangle
                        Width="1"
                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="2,0" />
                    <TextBlock
                        Text="{x:Bind ToggleOptionText, Mode=OneWay}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </ToggleButton>

            <TextBlock
                Grid.Row="3"
                Text="{x:Bind StatusText, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
