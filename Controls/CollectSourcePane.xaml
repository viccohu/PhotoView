<UserControl
    x:Class="PhotoView.Controls.CollectSourcePane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="PaneGhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="12"
        Background="Transparent">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Style="{ThemeResource BodyStrongTextBlockStyle}">
                <Run Text="载入区" />
                <Run Text="{x:Bind Subtitle, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </TextBlock>

            <ItemsControl
                Grid.Row="1"
                ItemsSource="{x:Bind SourceItems, Mode=OneWay}"
                Visibility="{x:Bind HasSourceItems, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,4"
                            Padding="8,4"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding DisplayName}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    FontSize="12" />
                                <Button
                                    Grid.Column="1"
                                    Tag="{Binding}"
                                    Click="RemoveSourceButton_Click"
                                    Style="{StaticResource PaneGhostButtonStyle}">
                                    <FontIcon
                                        Glyph="&#xE711;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="10" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ToggleButton
                Grid.Row="2"
                Content="{x:Bind ToggleOptionText, Mode=OneWay}"
                IsChecked="{x:Bind ToggleOptionValue, Mode=TwoWay}"
                Checked="ToggleOptionButton_CheckedChanged"
                Unchecked="ToggleOptionButton_CheckedChanged"
                Visibility="{x:Bind IsToggleOptionVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Button
                Grid.Row="3"
                HorizontalAlignment="Stretch"
                Click="LoadButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        Glyph="&#xF103;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="14" />
                    <TextBlock Text="载入" />
                </StackPanel>
            </Button>

            <ProgressBar
                Grid.Row="4"
                Height="4"
                IsIndeterminate="{x:Bind IsProgressIndeterminate, Mode=OneWay}"
                Maximum="100"
                Minimum="0"
                Value="{x:Bind ProgressValue, Mode=OneWay}"
                Visibility="{x:Bind IsProgressVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </Border>
</UserControl>
