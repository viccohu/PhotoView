<UserControl
    x:Class="PhotoView.Controls.NavigationPaneExplorer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:PhotoView.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NodeTypeToIconConverter x:Key="NodeTypeToIconConverter" />
        <Style x:Key="PaneGhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="8,8,8,12"
        Background="Transparent">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock
                    Text="{Binding Title}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Opacity="0.7"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Visibility="{Binding HasStatusText, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>

            <ItemsControl
                Grid.Row="1"
                ItemsSource="{Binding SourceItems}"
                Visibility="{Binding HasSourceItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:NavigationPaneSourceItem">
                        <Border
                            Margin="0,0,0,6"
                            Padding="8,5"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{x:Bind DisplayName}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                                <Button
                                    Grid.Column="1"
                                    Tag="{x:Bind}"
                                    Click="RemoveSourceButton_Click"
                                    Style="{StaticResource PaneGhostButtonStyle}">
                                    <FontIcon
                                        Glyph="&#xE711;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="12" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2" Spacing="8">
                <ToggleButton
                    Content="{Binding ToggleOptionText}"
                    IsChecked="{Binding ToggleOptionValue, Mode=TwoWay}"
                    Checked="ToggleOptionButton_CheckedChanged"
                    Unchecked="ToggleOptionButton_CheckedChanged"
                    Visibility="{Binding IsToggleOptionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <TextBlock
                    Text="{Binding StatusText}"
                    Opacity="0.72"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasStatusText, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ProgressBar
                    Height="4"
                    IsIndeterminate="{Binding IsProgressIndeterminate}"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ProgressValue}"
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Button
                    HorizontalAlignment="Stretch"
                    Click="PrimaryActionButton_Click"
                    Visibility="{Binding HasPrimaryAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            Glyph="{Binding PrimaryAction.Glyph}"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="16" />
                        <TextBlock Text="{Binding PrimaryAction.Text}" />
                    </StackPanel>
                </Button>
            </StackPanel>

<TreeView
                x:Name="FolderTreeView"
                Grid.Row="3"
                ItemsSource="{Binding RootNodes}"
                Expanding="FolderTreeView_Expanding"
                ItemInvoked="FolderTreeView_ItemInvoked">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="models:FolderNode">
                        <TreeViewItem
                            ItemsSource="{x:Bind Children}"
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                            HasUnrealizedChildren="{x:Bind HasExpandableChildren, Mode=OneWay}"
                            DoubleTapped="TreeViewItem_DoubleTapped"
                            RightTapped="TreeViewItem_RightTapped">
                            <Grid Tag="{x:Bind}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Glyph="{x:Bind NodeType, Converter={StaticResource NodeTypeToIconConverter}}"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="16" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
    </Border>
</UserControl>
