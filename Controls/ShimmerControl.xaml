<UserControl
    x:Class="PhotoView.Controls.ShimmerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="300">

    <UserControl.Resources>
        <Storyboard x:Name="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="ShimmerTranslate"
                Storyboard.TargetProperty="X"
                From="-300"
                To="300"
                Duration="0:0:1.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <ContentPresenter
            x:Name="ContentPresenter"
            Content="{x:Bind Content, Mode=OneWay}"/>

        <Rectangle
            x:Name="ShimmerOverlay"
            Visibility="Collapsed"
            IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#30FFFFFF" Offset="0.3"/>
                    <GradientStop Color="#50FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#30FFFFFF" Offset="0.7"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="ShimmerTranslate" X="-300"/>
            </Rectangle.RenderTransform>
        </Rectangle>
    </Grid>
</UserControl>
