<UserControl
    x:Class="PhotoView.Controls.ImageViewerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Grid
        x:Name="BackgroundOverlay"
       Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        Opacity="0"
        Tapped="BackgroundOverlay_Tapped">
        
        <Grid
            x:Name="AnimationContainer"
            
            Opacity="0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 阶段1：动画用 -->
            <Grid
                x:Name="AnimationImageContainer"
                Grid.Column="0"
                >
                <Image
                    x:Name="AnimationImage"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Grid>

            <!-- 阶段2：查看器 -->
            <Grid
                x:Name="ImageContainer"
                Grid.Column="0"
                
                Tapped="ImageContainer_Tapped"
                PointerPressed="ImageContainer_PointerPressed"
                PointerMoved="ImageContainer_PointerMoved"
                PointerReleased="ImageContainer_PointerReleased"
                PointerCanceled="ImageContainer_PointerReleased"
                PointerCaptureLost="ImageContainer_PointerReleased"
                PointerWheelChanged="ImageContainer_PointerWheelChanged"
                SizeChanged="ImageContainer_SizeChanged"
                Opacity="0">
                <Grid.Clip>
                    <RectangleGeometry x:Name="ImageClip"/>
                </Grid.Clip>
                <Grid
                    x:Name="ImageTransformContainer"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    DoubleTapped="ImageTransformContainer_DoubleTapped">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image
                        x:Name="MainImage"
                        Stretch="Uniform"/>
                </Grid>
            </Grid>

            <Border
                BorderBrush="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1.5,0,0,0"
                x:Name="InfoPanel"
                 CornerRadius="12,0,0,12"
                Grid.Column="1"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                Padding="12"
                Tapped="InfoPanel_Tapped">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Grid>
                            <TextBlock Text="信息" Style="{ThemeResource BodyTextBlockStyle}" Margin="0,0,48,0"/>
                            <Button
                                x:Name="CloseButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Click="CloseButton_Click">
                                <FontIcon Glyph="&#xE711;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                            </Button>
                        </Grid>

                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B9;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TextBlock x:Name="ImageNameTextBox" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE787;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <DatePicker x:Name="CaptureDatePicker"  IsEnabled="False" HorizontalAlignment="Center" Width="300"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC92;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TimePicker x:Name="CaptureTimePicker" IsEnabled="False" HorizontalAlignment="Center" Width="300"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xF4A5;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TextBlock Text="大小信息" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="24,0,0,0">
                                <TextBlock x:Name="ResolutionTextBlock" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <TextBlock x:Name="FileSizeTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE722;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TextBlock Text="设备信息" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel x:Name="DeviceInfoPanel" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0" 
                                          Visibility="Collapsed">
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TextBlock Text="文件路径" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel x:Name="FilePathPanel" Spacing="8" Margin="24,0,0,0" >
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
