<UserControl
    x:Class="PhotoView.Controls.ImageViewerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    xmlns:converters="using:PhotoView.Converters"
    xmlns:controls="using:PhotoView.Controls"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400"
    IsTabStop="True"
    TabIndex="0">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
        
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#E6FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonSurface.Background" Value="#66000000"/>
                                            <Setter Target="ButtonSurface.BorderBrush" Value="#99FFFFFF"/>
                                            <Setter Target="BackIcon.Opacity" Value="1"/>
                                            <Setter Target="ButtonScale.ScaleX" Value="1.06"/>
                                            <Setter Target="ButtonScale.ScaleY" Value="1.06"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonSurface.Background" Value="#80000000"/>
                                            <Setter Target="ButtonSurface.BorderBrush" Value="#CCFFFFFF"/>
                                            <Setter Target="BackIcon.Opacity" Value="1"/>
                                            <Setter Target="ButtonScale.ScaleX" Value="0.96"/>
                                            <Setter Target="ButtonScale.ScaleY" Value="0.96"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonSurface.Opacity" Value="0.35"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <FontIcon
                                    x:Name="BackIcon"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Glyph="&#xE72B;"
                                    FontSize="18"
                                    Foreground="{TemplateBinding Foreground}"
                                    Opacity="0.78"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid
        x:Name="BackgroundOverlay"
       Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        Opacity="0">

        <Grid
            x:Name="AnimationContainer"

            Opacity="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="AnimationImageContainer"
                Grid.Column="0"
                >
                <Image
                    x:Name="AnimationImage"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Grid>

            <Grid
                x:Name="ImageContainer"
                Grid.Column="0"

                Tapped="ImageContainer_Tapped"
                PointerPressed="ImageContainer_PointerPressed"
                PointerMoved="ImageContainer_PointerMoved"
                PointerReleased="ImageContainer_PointerReleased"
                PointerCanceled="ImageContainer_PointerReleased"
                PointerCaptureLost="ImageContainer_PointerReleased"
                PointerWheelChanged="ImageContainer_PointerWheelChanged"
                SizeChanged="ImageContainer_SizeChanged"
                Opacity="0">
                <Grid.Clip>
                    <RectangleGeometry x:Name="ImageClip"/>
                </Grid.Clip>
                <Grid
                    x:Name="ImageTransformContainer"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    DoubleTapped="ImageTransformContainer_DoubleTapped">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image
                        x:Name="MainImage"
                        Stretch="Uniform"/>
                </Grid>
                
                <!-- 关闭按钮 -->
                <Button
                    x:Name="CloseButton"
                    Width="44"
                    Height="44"
                    Margin="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource CloseButtonStyle}"
                    Click="CloseButton_Click">
                </Button>
            </Grid>

            <Border
                BorderBrush="{ThemeResource SolidBackgroundFillColorBaseAltBrush}"
                BorderThickness="1.5,0,0,0"
                x:Name="InfoPanel"
                 CornerRadius="12,0,0,12"
                Grid.Column="1"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                Padding="12"
                Tapped="InfoPanel_Tapped">
                <controls:ImageInfoPanelControl ViewModel="{x:Bind ViewModel, Mode=OneWay}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
