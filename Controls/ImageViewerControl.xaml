<UserControl
    x:Class="PhotoView.Controls.ImageViewerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoView.Models"
    xmlns:converters="using:PhotoView.Converters"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
    </UserControl.Resources>

    <Grid
        x:Name="BackgroundOverlay"
       Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        Opacity="0"
        Tapped="BackgroundOverlay_Tapped">
        
        <Grid
            x:Name="AnimationContainer"
            
            Opacity="0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 阶段1：动画用 -->
            <Grid
                x:Name="AnimationImageContainer"
                Grid.Column="0"
                >
                <Image
                    x:Name="AnimationImage"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Grid>

            <!-- 阶段2：查看器 -->
            <Grid
                x:Name="ImageContainer"
                Grid.Column="0"
                
                Tapped="ImageContainer_Tapped"
                PointerPressed="ImageContainer_PointerPressed"
                PointerMoved="ImageContainer_PointerMoved"
                PointerReleased="ImageContainer_PointerReleased"
                PointerCanceled="ImageContainer_PointerReleased"
                PointerCaptureLost="ImageContainer_PointerReleased"
                PointerWheelChanged="ImageContainer_PointerWheelChanged"
                SizeChanged="ImageContainer_SizeChanged"
                Opacity="0">
                <Grid.Clip>
                    <RectangleGeometry x:Name="ImageClip"/>
                </Grid.Clip>
                <Grid
                    x:Name="ImageTransformContainer"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    DoubleTapped="ImageTransformContainer_DoubleTapped">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image
                        x:Name="MainImage"
                        Stretch="Uniform"/>
                </Grid>
            </Grid>

            <Border
                BorderBrush="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1.5,0,0,0"
                x:Name="InfoPanel"
                 CornerRadius="12,0,0,12"
                Grid.Column="1"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                Padding="12"
                Tapped="InfoPanel_Tapped">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock Text="信息" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>

                        <TextBox 
                            Text="{Binding ImageName, Mode=OneWay}"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            AcceptsReturn="False"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Padding="8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderThickness="0"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="评级" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <RatingControl 
                                    x:Name="ImageRatingControl"
                                    Value="{Binding Rating, Mode=TwoWay}"
                                    MaxRating="5"
                                    IsClearEnabled="True"
                                    HorizontalAlignment="Left"
                                    ValueChanged="ImageRatingControl_ValueChanged"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE787;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <DatePicker Date="{Binding CaptureDate, Mode=OneWay}" IsEnabled="False" HorizontalAlignment="Center" Width="300"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC92;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TimePicker Time="{Binding CaptureTime, Mode=OneWay}" IsEnabled="False" HorizontalAlignment="Center" Width="300"/>
                            </StackPanel>
                        </StackPanel>

                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8"
                            Padding="12">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                    <TextBlock Text="文件信息" Style="{ThemeResource BodyTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel Spacing="4" Margin="24,0,0,0">
                                    <Grid Height="32" 
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="Resolution_Tapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="尺寸" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Resolution, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="FileSize_Tapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="大小" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FileSize, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="Dpi_Tapped"
                                          Visibility="{Binding Dpi, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="DPI" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Dpi, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="BitDepth_Tapped"
                                          Visibility="{Binding BitDepth, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="色深" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding BitDepth, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="RatingSource_Tapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="评级来源" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RatingSource, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="{Binding HasDeviceInfo, Mode=OneWay}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE722;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                    <TextBlock Text="设备信息" Style="{ThemeResource BodyTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel Spacing="4" Margin="24,0,0,0">
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="CameraModel_Tapped"
                                          Visibility="{Binding HasDeviceInfo, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="相机" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DeviceInfo, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <TextBlock Text="{x:Bind}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding LensModel, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="LensModel_Tapped"
                                          Visibility="{Binding LensModel, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="镜头" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding LensModel, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding FocalLength, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="FocalLength_Tapped"
                                          Visibility="{Binding FocalLength, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="焦距" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FocalLength, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding ExposureTime, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="ExposureTime_Tapped"
                                          Visibility="{Binding ExposureTime, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="曝光" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Style="{ThemeResource CaptionTextBlockStyle}">
                                            <Run Text="{Binding ExposureTime, Mode=OneWay}"/>
                                            <Run Text="  "/>
                                            <Run Text="{Binding FNumber, Mode=OneWay}"/>
                                            <Run Text="  "/>
                                            <Run Text="{Binding Iso, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding ExposureProgram, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="ExposureProgram_Tapped"
                                          Visibility="{Binding ExposureProgram, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="程序" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ExposureProgram, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding ExposureBias, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="ExposureBias_Tapped"
                                          Visibility="{Binding ExposureBias, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="补偿" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ExposureBias, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                    <AppBarSeparator Visibility="{Binding Flash, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                    <Grid Height="32"
                                          Background="Transparent"
                                          PointerEntered="InfoItem_PointerEntered"
                                          PointerExited="InfoItem_PointerExited"
                                          Tapped="Flash_Tapped"
                                          Visibility="{Binding Flash, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="闪光灯" Width="60" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Flash, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                <TextBlock Text="文件路径" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding FilePaths, Mode=OneWay}" Margin="24,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:FilePathItem">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border 
                                                Grid.Column="0"
                                                Background="{Binding FileFormatColor, Converter={StaticResource StringToColorConverter}, Mode=OneWay}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center">
                                                <TextBlock 
                                                    Text="{Binding FileFormat, Mode=OneWay}"
                                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                                    Foreground="White"
                                                    FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock 
                                                Grid.Column="1" 
                                                Text="{x:Bind Path}" 
                                                TextWrapping="Wrap"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                IsTextSelectionEnabled="True"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                PointerPressed="PathText_PointerPressed"/>
                                            <Button
                                                Grid.Column="2"
                                                Command="{x:Bind CopyPathCommand}"
                                                Padding="8"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0">
                                                <FontIcon Glyph="&#xE8C8;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
